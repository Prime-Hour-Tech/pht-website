{
  "name": "pht-website",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": "^22.12.0 || ^24.0.0"
  },
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:studio": "pnpm --filter studio dev",
    "build:web": "pnpm --filter web build",
    "build:studio": "pnpm --filter studio build",
    "deploy:studio": "pnpm --filter studio run deploy",
    "seed:studio": "pnpm --filter studio seed",
    "seed:studio:replace": "pnpm --filter studio seed:replace",
    "test": "pnpm -r test"
  }
}
