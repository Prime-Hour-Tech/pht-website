# Normalize line endings: store as LF in the repo, check out with LF
* text=auto eol=lf

# Force LF for scripts
*.sh text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
