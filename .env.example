# Sanity (build-time read access — server-side only)
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2026-05-01
# Required when the dataset is private. Generate at sanity.io/manage > project
# > API > Tokens. Use a Read-only token. Never expose to browsers.
SANITY_READ_TOKEN=

# Public site URL — used for canonical + sitemap. Set in Vercel for production.
SITE_URL=http://localhost:4321

# Sanity Studio (browser-exposed, only used by apps/studio/.env)
# SANITY_STUDIO_PROJECT_ID=
# SANITY_STUDIO_DATASET=production
