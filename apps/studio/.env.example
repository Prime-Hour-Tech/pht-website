# Sanity Studio environment variables.
#
# Note: Sanity Studio is a browser SPA. Vite only exposes env vars prefixed
# with SANITY_STUDIO_ to the client bundle, so all studio vars use that prefix.

# Sanity project ID. Required — studio fails to load without it.
SANITY_STUDIO_PROJECT_ID=

# Dataset name. Default: "production".
SANITY_STUDIO_DATASET=production

# Vercel deploy hook URL. When set, the Studio's Deploy tool can trigger a web
# rebuild after publishing content. Get this from Vercel project settings →
# Git → Deploy Hooks. Leave unset to hide the Deploy tool.
SANITY_STUDIO_VERCEL_DEPLOY_HOOK=

# URL the Presentation Tool's iframe will load. In dev, this is the local Astro
# dev server (default below). In production, point at a deployed preview URL or
# the live site.
SANITY_STUDIO_PREVIEW_URL=http://localhost:4321
