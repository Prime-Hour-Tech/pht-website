---
import type { SwitchingPage } from "../../lib/sanity/types";
import HeadlineRichText from "../HeadlineRichText.astro";

interface Props {
  handle: SwitchingPage["handle"];
}

const { handle } = Astro.props;
---

<section class="bg-bg px-10 py-22 border-b border-line">
  <div class="max-w-content mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-[0.9fr_1.1fr] gap-16 items-end mb-12">
      <div>
        <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-4">
          ◆ {handle.eyebrow}
        </div>
        <h2
          class="font-serif font-medium text-ink m-0 tracking-display-tight"
          style="font-size: 52px; line-height: 1.02; text-wrap: balance;"
        >
          <HeadlineRichText value={handle.title} />
        </h2>
      </div>
      <p class="m-0 text-muted text-body-lg leading-body">{handle.deck}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-0">
      {handle.items.map((item, i) => {
        const num = String(i + 1).padStart(2, "0");
        return (
          <div
            class={`grid grid-cols-[44px_1fr] gap-4.5 py-5 ${
              i < 2 ? "md:border-t md:border-line" : ""
            } border-b border-line-soft`}
          >
            <div
              class="w-8 h-8 mt-0.5 rounded-full bg-accent/10 text-accent border border-accent/20 inline-flex items-center justify-center font-mono font-semibold text-[12px]"
            >
              {num}
            </div>
            <div>
              <div class="text-[16px] font-semibold text-ink leading-tight">
                {item.head}
              </div>
              <div class="mt-1 text-muted text-[14.5px] leading-body">
                {item.body}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
