---
import type { HeadlineRichText as HRT, ServiceCapability, IconName } from "../../lib/sanity/types";
import Icon from "../Icon.astro";
import HeadlineRichText from "../HeadlineRichText.astro";

interface Props {
  eyebrow: string;
  heading: HRT;
  iconName: IconName;
  capabilities: ServiceCapability[];
  specSheetUrl?: string;
}

const { eyebrow, heading, iconName, capabilities, specSheetUrl } = Astro.props;
---

<section class="bg-bg-alt py-24 px-5 md:px-10 border-b border-line">
  <div class="max-w-content mx-auto">
    <div class="flex items-baseline justify-between mb-8 flex-wrap gap-4">
      <div>
        <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-3">
          ◆ {eyebrow}
        </div>
        <h2
          class="font-serif font-medium text-ink m-0"
          style="font-size: clamp(30px, 6vw, 44px); letter-spacing: -0.025em; line-height: 1.05; text-wrap: balance;"
        >
          <HeadlineRichText value={heading} />
        </h2>
      </div>
      {specSheetUrl && (
        <a
          href={specSheetUrl}
          class="text-accent font-semibold no-underline text-body-sm"
        >
          Download spec sheet →
        </a>
      )}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {capabilities.map((cap) => (
        <div class="bg-bg border border-line rounded-lg p-6">
          <div class="flex justify-between items-center mb-3.5">
            <span class="size-9 rounded-md bg-accent/10 text-accent inline-flex items-center justify-center">
              <Icon name={iconName} size={18} />
            </span>
            <span class="font-mono text-micro text-muted uppercase tracking-mono-meta px-2 py-0.5 border border-line rounded">
              INCLUDED
            </span>
          </div>
          <h3 class="text-body-lg font-semibold text-ink m-0" style="letter-spacing: -0.01em; line-height: 1.2;">
            {cap.name}
          </h3>
          <p class="mt-1.5 text-muted text-body-sm leading-body m-0">
            {cap.body}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
