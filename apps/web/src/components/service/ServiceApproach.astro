---
import type { HeadlineRichText as HRT } from "../../lib/sanity/types";
import Icon from "../Icon.astro";
import HeadlineRichText from "../HeadlineRichText.astro";

interface Props {
  eyebrow: string;
  heading: HRT;
  body: string;
  bullets: string[];
}

const { eyebrow, heading, body, bullets } = Astro.props;
---

<section class="bg-bg py-24 px-5 md:px-10 border-b border-line">
  <div class="max-w-content mx-auto grid grid-cols-1 md:grid-cols-[0.9fr_1.1fr] gap-16 items-start">
    <div class="md:sticky md:top-24">
      <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-3.5">
        ◆ {eyebrow}
      </div>
      <h2
        class="font-serif font-medium text-ink m-0"
        style="font-size: clamp(30px, 6vw, 48px); letter-spacing: -0.025em; line-height: 1.05; text-wrap: balance;"
      >
        <HeadlineRichText value={heading} />
      </h2>
    </div>

    <div>
      <p class="text-muted text-body-lg leading-body m-0">{body}</p>
      <ul class="mt-7 p-0 list-none flex flex-col gap-3">
        {bullets.map((b) => (
          <li class="flex gap-3.5 text-ink text-body-base leading-body py-3.5 border-b border-line-soft items-start">
            <span class="text-accent mt-1"><Icon name="check" size={16} stroke={2} /></span>
            <span>{b}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
