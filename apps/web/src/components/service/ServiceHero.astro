---
import type { ServiceFull } from "../../lib/sanity/types";
import Icon from "../Icon.astro";
import HeadlineRichText from "../HeadlineRichText.astro";

interface Props {
  service: ServiceFull;
}

const { service } = Astro.props;
---

<section class="bg-dark text-dark-text px-5 md:px-10 py-20 relative overflow-hidden" aria-label="Service hero">
  <div
    aria-hidden="true"
    class="absolute -top-40 w-[480px] h-[480px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, color-mix(in srgb, var(--color-accent) 15%, transparent), transparent 70%); right: -120px;"
  ></div>

  <div class="max-w-content mx-auto grid grid-cols-1 md:grid-cols-[1.4fr_1fr] gap-14 items-end relative">
    <div>
      <div class="inline-flex items-center gap-3 mb-6">
        <span class="size-12 rounded-xl bg-accent/10 text-accent border border-accent/30 inline-flex items-center justify-center">
          <Icon name={service.iconName} size={22} />
        </span>
        <span class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase">
          {service.eyebrow}
        </span>
      </div>

      <h1
        class="font-serif font-medium text-dark-text m-0 leading-[0.96]"
        style="font-size: clamp(44px, 9vw, 88px); letter-spacing: -0.035em; text-wrap: balance;"
      >
        <HeadlineRichText value={service.headline} />
      </h1>

      <p class="mt-6 text-dark-muted text-body-lg leading-body max-w-[580px]">
        {service.deck}
      </p>

      <div class="mt-7 flex gap-3 items-center flex-wrap">
        <a
          href="/contact"
          class="btn btn-primary btn-md"
        >
          Schedule a discovery call <Icon name="arrow" size={16} />
        </a>
        {service.specSheetUrl && (
          <a
            href={service.specSheetUrl}
            class="btn btn-secondary-dark btn-md"
          >
            Read the spec sheet →
          </a>
        )}
      </div>
    </div>

    <div class="bg-white/[0.04] border border-dark-line rounded-xxl p-7 self-stretch flex flex-col justify-between">
      <div class="font-mono text-meta text-dark-muted tracking-mono-meta uppercase">
        ◆ At a glance
      </div>

      <div>
        <div
          class="font-serif font-medium text-dark-text leading-none"
          style="font-size: clamp(44px, 9vw, 88px); letter-spacing: -0.04em;"
        >
          {service.heroStat.k}
        </div>
        <div class="mt-2.5 text-dark-muted text-body-base leading-snug">
          {service.heroStat.v}
        </div>
      </div>

      {(service.heroPillLeft || service.heroPillRight) && (
        <div class={`pt-4 border-t border-dark-line flex items-center font-mono text-meta text-dark-muted uppercase tracking-mono-meta ${service.heroPillLeft && service.heroPillRight ? "justify-between" : "justify-start gap-6"}`}>
          {service.heroPillLeft && <span>{service.heroPillLeft}</span>}
          {service.heroPillRight && <span>{service.heroPillRight}</span>}
        </div>
      )}
    </div>
  </div>
</section>
