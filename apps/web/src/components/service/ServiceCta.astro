---
import type { ContactInfo, HeadlineRichText as HRT } from "../../lib/sanity/types";
import Icon from "../Icon.astro";
import HeadlineRichText from "../HeadlineRichText.astro";

interface Props {
  serviceName: string;
  eyebrow: string;
  deck: string;
  contactInfo: ContactInfo;
}

const { serviceName, eyebrow, deck, contactInfo } = Astro.props;

// Build a synthetic Portable Text headline interpolating the service name.
// Template: "See if {serviceName} from PHT [accent: fits your business.]"
const heading: HRT = [
  {
    _type: "block",
    _key: "cta-h",
    style: "normal",
    markDefs: [{ _key: "acc", _type: "accent" }],
    children: [
      {
        _type: "span",
        _key: "s1",
        text: `See if ${serviceName} from PHT `,
        marks: [],
      },
      {
        _type: "span",
        _key: "s2",
        text: "fits your business.",
        marks: ["acc"],
      },
    ],
  },
];
---

<section class="bg-bg py-24 px-5 md:px-10">
  <div class="max-w-narrow mx-auto grid grid-cols-1 md:grid-cols-[1.4fr_1fr] gap-14 items-center">
    <div>
      <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-3.5">
        ◆ {eyebrow}
      </div>
      <h2
        class="font-serif font-medium text-ink m-0"
        style="font-size: clamp(32px, 7vw, 52px); line-height: 1.02; letter-spacing: -0.03em; text-wrap: balance;"
      >
        <HeadlineRichText value={heading} />
      </h2>
      <p class="mt-4 text-muted text-body-lg leading-snug max-w-[500px]">
        {deck}
      </p>
    </div>

    <div class="bg-bg-alt border border-line rounded-xxl p-7">
      <div class="font-semibold text-body-base text-ink mb-4">{contactInfo.cardTitle}</div>
      <a
        href={`tel:${contactInfo.phone.dial}`}
        class="flex items-center gap-3 py-3 border-t border-line-soft text-ink no-underline text-[15px]"
      >
        <Icon name="phone" size={18} stroke={1.5} />
        <span class="flex-1">{contactInfo.phone.display}</span>
        <Icon name="arrowSm" size={14} />
      </a>
      <a
        href={`mailto:${contactInfo.email}`}
        class="flex items-center gap-3 py-3 border-t border-line-soft text-ink no-underline text-[15px]"
      >
        <Icon name="mail" size={18} stroke={1.5} />
        <span class="flex-1 break-all">{contactInfo.email}</span>
        <Icon name="arrowSm" size={14} />
      </a>
      <a
        href="/contact"
        class="btn btn-primary btn-md w-full mt-4"
      >
        Schedule a discovery call
        <Icon name="arrow" size={16} />
      </a>
    </div>
  </div>
</section>
