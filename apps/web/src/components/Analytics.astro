---
// Google Tag Manager loader, gated on cookie consent.
//
// Behavior:
//   - When PUBLIC_GTM_CONTAINER_ID is unset, this component renders NOTHING.
//     Zero Google scripts ship until the env var is configured in Vercel.
//   - When the env var is set, an inline loader script ships. The loader:
//       1. On page load, checks localStorage["pht-cookie-consent"]. If
//          "accepted", injects the GTM <script> tag (gtm.js).
//       2. Subscribes to the "pht-cookie-consent-changed" event from the
//          cookie banner. When the user accepts mid-session, injects GTM live.
//       3. Idempotent — GTM is injected at most once per page.
//       4. After live (post-consent) injection, pushes a synthetic page_view
//          to dataLayer so GTM's GA4 config can capture the current page.
//          (gtm.js's auto-pageview only fires on initial script load, so a
//          user who accepts after the page is rendered would otherwise lose
//          the current page from the session record.)
//
// Reject / settings / no-choice all result in no GTM. The banner alone is the
// consent surface — this component never auto-accepts.

const gtmContainerId = import.meta.env.PUBLIC_GTM_CONTAINER_ID;
---

{gtmContainerId && (
  <script is:inline define:vars={{ gtmContainerId }}>
    (function () {
      var STORAGE_KEY = "pht-cookie-consent";
      var loaded = false;

      function injectGtm() {
        if (loaded) return;
        loaded = true;

        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          "gtm.start": new Date().getTime(),
          event: "gtm.js",
        });

        var s = document.createElement("script");
        s.async = true;
        s.src = "https://www.googletagmanager.com/gtm.js?id=" + gtmContainerId;
        document.head.appendChild(s);
      }

      function injectAfterConsent() {
        injectGtm();
        // Recover the page_view that gtm.js's auto-pageview can't fire
        // (since we injected mid-session).
        window.dataLayer.push({
          event: "page_view",
          page_location: window.location.href,
          page_path: window.location.pathname,
        });
      }

      try {
        if (localStorage.getItem(STORAGE_KEY) === "accepted") {
          injectGtm();
        }
      } catch (_) { /* localStorage blocked — skip */ }

      document.addEventListener("pht-cookie-consent-changed", function (e) {
        var choice = e && e.detail && e.detail.choice;
        if (choice === "accepted") {
          injectAfterConsent();
        }
      });
    })();
  </script>
)}
