---
import type { LandingPage } from "../../lib/sanity/types";
import HeadlineRichText from "../HeadlineRichText.astro";

interface Props {
  problem: LandingPage["problem"];
}

const { problem } = Astro.props;
---

<section class="bg-bg px-5 md:px-10 py-24 border-t border-line">
  <div class="max-w-content mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-[0.9fr_1.1fr] gap-16 items-end mb-12">
      <div>
        <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-4">
          ◆ {problem.eyebrow}
        </div>
        <h2
          class="font-serif font-medium text-ink m-0 tracking-display-tight"
          style="font-size: clamp(32px, 7vw, 52px); line-height: 1.02; text-wrap: balance;"
        >
          <HeadlineRichText value={problem.title} />
        </h2>
      </div>
      <p class="m-0 text-muted text-body-lg leading-body">{problem.deck}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {problem.items.map((item, i) => {
        const num = String(i + 1).padStart(2, "0");
        return (
          <div class="bg-bg border border-line rounded-xl p-7 flex flex-col gap-3.5">
            <div class="flex items-center justify-between">
              <span class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase">
                Pain · {num}
              </span>
              <span
                class="w-7 h-7 rounded-full border border-line inline-flex items-center justify-center font-mono text-[12px] text-muted"
              >
                {num}
              </span>
            </div>
            <h3
              class="font-serif font-medium text-ink m-0"
              style="font-size: 24px; letter-spacing: -0.015em; line-height: 1.15;"
            >
              {item.head}
            </h3>
            <p class="m-0 text-muted text-[14.5px] leading-body">{item.body}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>
