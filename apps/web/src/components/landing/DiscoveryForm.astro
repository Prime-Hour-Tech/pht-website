---
import type { LandingPage, ContactInfo } from "../../lib/sanity/types";
import Icon from "../Icon.astro";

interface Props {
  form: LandingPage["form"];
  slug: string;
  contactInfo: ContactInfo;
}

const { form, slug, contactInfo } = Astro.props;

const formAction = import.meta.env.CONTACT_FORM_URL ?? "#";
if (formAction === "#") {
  // eslint-disable-next-line no-console
  console.warn(
    `[DiscoveryForm] CONTACT_FORM_URL env var not set; /landing/${slug} form renders with action="#". Set it on the Vercel project before launch.`,
  );
}

const redirectUrl = `/landing/${slug}?submitted=true`;
const sourceValue = `landing-${slug}`;
---

<div id="discovery-form" class="w-full">
  <!-- FORM (initially visible) -->
  <div
    id="discovery-form-container"
    class="bg-bg border border-line rounded-xl p-7 shadow-card"
  >
    <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-2.5">
      ◆ {form.cardEyebrow}
    </div>
    <h3
      class="font-serif font-medium text-ink m-0"
      style="font-size: 28px; line-height: 1.1; letter-spacing: -0.02em;"
    >
      {form.heading}
    </h3>
    <p class="mt-2.5 mb-5 text-muted text-[14px] leading-body">{form.deck}</p>

    <form
      action={formAction}
      method="POST"
      enctype="application/x-www-form-urlencoded"
      class="flex flex-col gap-3"
    >
      <input type="hidden" name="source" value={sourceValue} />
      <input type="hidden" name="_gotcha" value="" />
      <input type="text" name="botcheck" value="" tabindex="-1" autocomplete="off" style="display:none" />
      <input type="hidden" name="_next" value={redirectUrl} />
      <input type="hidden" name="_redirect" value={redirectUrl} />
      <input type="hidden" name="redirect" value={redirectUrl} />

      <label class="flex flex-col gap-1.5">
        <span class="font-mono text-[11px] text-muted tracking-mono-eyebrow uppercase">Name</span>
        <input
          name="name"
          required
          placeholder="Jane Smith"
          class="bg-bg-alt border border-line rounded-md px-3.5 py-3 text-ink text-[14.5px]"
        />
      </label>

      <label class="flex flex-col gap-1.5">
        <span class="font-mono text-[11px] text-muted tracking-mono-eyebrow uppercase">Work email</span>
        <input
          type="email"
          name="email"
          required
          placeholder="jane@company.com"
          class="bg-bg-alt border border-line rounded-md px-3.5 py-3 text-ink text-[14.5px]"
        />
      </label>

      <label class="flex flex-col gap-1.5">
        <span class="font-mono text-[11px] text-muted tracking-mono-eyebrow uppercase">Company</span>
        <input
          name="company"
          required
          placeholder="Acme LLC · 32 seats"
          class="bg-bg-alt border border-line rounded-md px-3.5 py-3 text-ink text-[14.5px]"
        />
      </label>

      <label class="flex flex-col gap-1.5">
        <span class="font-mono text-[11px] text-muted tracking-mono-eyebrow uppercase">
          What's the situation? (optional)
        </span>
        <textarea
          name="situation"
          rows="3"
          placeholder={form.situationPlaceholder}
          class="bg-bg-alt border border-line rounded-md px-3.5 py-3 text-ink text-[14.5px] resize-y"
        ></textarea>
      </label>

      <button
        type="submit"
        class="mt-3 bg-accent text-white font-semibold rounded-md inline-flex items-center justify-center gap-2.5 shadow-button-accent"
        style="padding: 14px 22px; font-size: 15px;"
      >
        {form.submitLabel}
        <Icon name="arrow" size={16} />
      </button>

      <div class="mt-3 flex flex-wrap gap-2 items-center justify-between font-mono text-[10.5px] text-muted tracking-mono-eyebrow uppercase">
        <span class="inline-flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-[#22c55e] inline-block"></span>
          {form.replyNote}
        </span>
        <span>
          or
          <a href={`tel:${contactInfo.phone.dial}`} class="text-accent no-underline font-semibold">
            call {contactInfo.phone.display}
          </a>
        </span>
      </div>
    </form>
  </div>

  <!-- SUCCESS STATE (initially hidden) -->
  <div
    id="discovery-success-container"
    class="bg-bg border border-line rounded-xl p-7 shadow-card"
    style="display: none;"
  >
    <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-3">
      ◆ Sent
    </div>
    <h3
      class="font-serif font-medium text-ink m-0"
      style="font-size: 28px; line-height: 1.1; letter-spacing: -0.02em;"
    >
      {form.successHeading}
    </h3>
    <p class="mt-4 m-0 text-muted text-[15px] leading-body">{form.successBody}</p>
  </div>
</div>

<script is:inline>
  (function () {
    var params = new URLSearchParams(window.location.search);
    if (params.get("submitted") === "true") {
      var formEl = document.getElementById("discovery-form-container");
      var successEl = document.getElementById("discovery-success-container");
      if (formEl && successEl) {
        formEl.style.display = "none";
        successEl.style.display = "";
        try {
          window.history.replaceState({}, "", window.location.pathname);
        } catch (_) { /* ignore */ }
      }
    }
  })();
</script>
