---
import type { LandingPage } from "../../lib/sanity/types";
import HeadlineRichText from "../HeadlineRichText.astro";
import Icon from "../Icon.astro";

interface Props {
  included: LandingPage["included"];
}

const { included } = Astro.props;
---

<section class="bg-bg-alt px-10 py-24 border-y border-line">
  <div class="max-w-content mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-[0.9fr_1.1fr] gap-16 items-end mb-12">
      <div>
        <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-4">
          ◆ {included.eyebrow}
        </div>
        <h2
          class="font-serif font-medium text-ink m-0 tracking-display-tight"
          style="font-size: 52px; line-height: 1.02; text-wrap: balance;"
        >
          <HeadlineRichText value={included.title} />
        </h2>
      </div>
      <p class="m-0 text-muted text-body-lg leading-body">{included.deck}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-0">
      {included.bullets.map((b, i) => (
        <div
          class={`grid grid-cols-[24px_1fr] gap-4 py-5 ${
            i < 2 ? "md:border-t md:border-line" : ""
          } border-b border-line-soft`}
        >
          <span class="text-accent mt-0.5">
            <Icon name="check" size={18} stroke={2} />
          </span>
          <div>
            <div class="text-[16px] font-semibold text-ink leading-tight">
              {b.head}
            </div>
            <div class="mt-1 text-muted text-[14.5px] leading-body">
              {b.body}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
