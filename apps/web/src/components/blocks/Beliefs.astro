---
import type { BeliefsBlock } from "../../lib/sanity/types";

interface Props {
  block: BeliefsBlock;
}

const { block } = Astro.props;
---

<section class="bg-bg-alt py-24 px-10 border-b border-line">
  <div class="max-w-content mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-[1fr_1.4fr] gap-20 items-start">
      <div class="md:sticky md:top-24">
        <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-3.5">
          {block.eyebrow}
        </div>
        <h2 class="font-serif font-medium tracking-display leading-display text-ink m-0" style="font-size: 56px;">
          {block.heading}
        </h2>
        {block.deck && (
          <p class="mt-4 text-muted text-body-md leading-body-lg max-w-[320px]">
            {block.deck}
          </p>
        )}
      </div>

      <ol class="list-none p-0 m-0">
        {block.items.map((b, i) => (
          <li
            class={`grid grid-cols-[60px_1fr] gap-6 py-6 items-center ${i === 0 ? "" : "border-t border-line"}`}
          >
            <span class="font-mono text-label text-accent tracking-mono-meta font-semibold">
              P/{String(i + 1).padStart(2, "0")}
            </span>
            <span class="font-serif text-serif-sm font-medium tracking-h3 leading-snug text-ink">
              {b}
            </span>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>
