---
import type { IndustriesDontSeeYoursBlock } from "../../lib/sanity/types";
import HeadlineRichText from "../HeadlineRichText.astro";
import Icon from "../Icon.astro";

interface Props {
  block: IndustriesDontSeeYoursBlock;
}

const { block } = Astro.props;
---

<section class="bg-bg py-20 px-5 md:px-10">
  <div class="max-w-narrow mx-auto text-center">
    <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-4">
      ◆ {block.eyebrow}
    </div>
    <h2
      class="font-serif font-medium text-ink m-0 mx-auto max-w-[820px] tracking-display-tight"
      style="font-size: clamp(34px, 7vw, 56px); line-height: 1; text-wrap: balance;"
    >
      <HeadlineRichText value={block.heading} />
    </h2>
    <p class="mt-5 text-muted text-[17px] leading-snug max-w-[620px] mx-auto">{block.deck}</p>
    <div class="mt-7 inline-flex gap-3 flex-wrap justify-center">
      <a
        href={block.primaryCta.href}
        class="btn btn-primary btn-md"
      >
        {block.primaryCta.label}
        <Icon name="arrow" size={16} />
      </a>
      <a
        href={block.secondaryCta.href}
        class="btn btn-secondary btn-md"
      >
        {block.secondaryCta.label} →
      </a>
    </div>
  </div>
</section>
