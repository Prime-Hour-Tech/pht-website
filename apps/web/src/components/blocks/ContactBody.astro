---
import type { ContactBodyBlock } from "../../lib/sanity/types";
import { getContactInfo } from "../../lib/sanity/client";
import Icon from "../Icon.astro";

interface Props {
  block: ContactBodyBlock;
}

const { block } = Astro.props;
const contactInfo = await getContactInfo();

if (!contactInfo) {
  throw new Error("Contact Info singleton not found in Sanity (required by ContactBody block).");
}

const formAction = import.meta.env.CONTACT_FORM_URL ?? "#";
if (formAction === "#") {
  // eslint-disable-next-line no-console
  console.warn("[ContactBody] CONTACT_FORM_URL env var not set; form renders with action=\"#\". Set it on the Vercel project before launch.");
}

const sizeOptions = ["1–10", "10–50", "50–250", "250+"];
---

<section class="bg-bg px-10 py-16">
  <div class="max-w-content mx-auto grid grid-cols-1 md:grid-cols-[1.4fr_1fr] gap-14 items-start">

    <!-- FORM (initially visible) -->
    <div
      id="contact-form-container"
      class="bg-bg-alt border border-line rounded-xl p-10 shadow-card"
    >
      <div class="font-mono text-[11px] text-muted tracking-mono-eyebrow uppercase mb-3">
        Step 1 of 1 · ~2 min
      </div>
      <h2
        class="font-serif font-medium text-ink m-0"
        style="font-size: 36px; line-height: 1.1; letter-spacing: -0.02em;"
      >
        {block.formHeading}
      </h2>
      <p class="mt-2 mb-7 text-muted text-[15px]">{block.formDeck}</p>

      <form
        action={formAction}
        method="POST"
        enctype="application/x-www-form-urlencoded"
        class="flex flex-col gap-4"
      >
        <!-- honeypots (Formspree + Web3Forms) -->
        <input type="hidden" name="_gotcha" value="" />
        <input type="text" name="botcheck" value="" tabindex="-1" autocomplete="off" style="display:none" />

        <!-- success redirects (Formspree / Basin / Web3Forms) -->
        <input type="hidden" name="_next" value="/contact?submitted=true" />
        <input type="hidden" name="_redirect" value="/contact?submitted=true" />
        <input type="hidden" name="redirect" value="/contact?submitted=true" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <label class="flex flex-col gap-2">
            <span class="text-[13px] font-medium text-ink">Full name *</span>
            <input name="name" required placeholder="Jane Doe"
              class="border border-line rounded-md px-3.5 py-3 bg-white text-ink text-[15px]" />
          </label>
          <label class="flex flex-col gap-2">
            <span class="text-[13px] font-medium text-ink">Company *</span>
            <input name="company" required placeholder="Acme LLC"
              class="border border-line rounded-md px-3.5 py-3 bg-white text-ink text-[15px]" />
          </label>
          <label class="flex flex-col gap-2">
            <span class="text-[13px] font-medium text-ink">Work email *</span>
            <input type="email" name="email" required placeholder="jane@acme.com"
              class="border border-line rounded-md px-3.5 py-3 bg-white text-ink text-[15px]" />
          </label>
          <label class="flex flex-col gap-2">
            <span class="text-[13px] font-medium text-ink">Phone</span>
            <input type="tel" name="phone" placeholder="(555) 555-5555"
              class="border border-line rounded-md px-3.5 py-3 bg-white text-ink text-[15px]" />
          </label>
        </div>

        <label class="flex flex-col gap-2">
          <span class="text-[13px] font-medium text-ink">Company size</span>
          <select name="company_size"
            class="border border-line rounded-md px-3.5 py-3 bg-white text-ink text-[15px]">
            {sizeOptions.map((s) => <option value={s}>{s}</option>)}
          </select>
        </label>

        <fieldset class="m-0 p-0 border-0">
          <legend class="text-[13px] font-medium text-ink mb-2.5">What's prompting this conversation? *</legend>
          <div class="flex gap-2 flex-wrap">
            {block.promptingOptions.map((opt) => (
              <label
                class="prompting-chip inline-flex items-center gap-1.5 px-3.5 py-2 rounded-full border border-line bg-white text-ink text-[13.5px] font-medium cursor-pointer"
              >
                <input
                  type="radio"
                  name="prompting"
                  value={opt}
                  required
                  class="sr-only peer"
                />
                <span class="chip-check opacity-0 peer-checked:opacity-100 text-accent inline-flex">
                  <Icon name="check" size={13} stroke={2.2} />
                </span>
                <span>{opt}</span>
              </label>
            ))}
          </div>
        </fieldset>

        <label class="flex flex-col gap-2">
          <span class="text-[13px] font-medium text-ink">Anything else we should know?</span>
          <textarea
            name="message"
            rows="4"
            placeholder="Stack you're running, current pain points, ideal start date…"
            class="border border-line rounded-md px-3.5 py-3 bg-white text-ink text-[15px] resize-y"
          ></textarea>
        </label>

        <div class="mt-3 flex items-center gap-4 flex-wrap">
          <button
            type="submit"
            class="bg-accent text-white font-semibold rounded-full inline-flex items-center gap-2.5 shadow-button-accent"
            style="padding: 14px 24px; font-size: 15px;"
          >
            {block.submitLabel}
            <Icon name="arrow" size={16} />
          </button>
          {block.submitNote && (
            <span class="font-mono text-[11px] text-muted tracking-[0.5px]">{block.submitNote}</span>
          )}
        </div>
      </form>
    </div>

    <!-- SUCCESS STATE (initially hidden) -->
    <div
      id="contact-success-container"
      class="bg-bg-alt border border-line rounded-xl p-10 shadow-card"
      style="display: none;"
    >
      <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-3">
        ◆ Sent
      </div>
      <h2
        class="font-serif font-medium text-ink m-0"
        style="font-size: 36px; line-height: 1.1; letter-spacing: -0.02em;"
      >
        {block.successHeading}
      </h2>
      <p class="mt-4 text-muted text-[16px] leading-body">{block.successBody}</p>
    </div>

    <!-- CONTACT PANELS -->
    <div class="flex flex-col gap-4">
      <a
        href={`tel:${contactInfo.phone.dial}`}
        class="bg-white border border-line rounded-xl p-5 no-underline text-ink block"
      >
        <div class="flex items-center gap-3 mb-1.5">
          <span class="w-8 h-8 rounded-md bg-accent/15 text-accent inline-flex items-center justify-center">
            <Icon name="phone" size={16} stroke={1.7} />
          </span>
          <span class="font-mono text-[11px] text-muted tracking-mono-eyebrow uppercase">Call us</span>
          <Icon name="arrowSm" size={14} class="ml-auto text-muted" />
        </div>
        <div class="font-serif font-medium text-ink" style="font-size: 22px; letter-spacing: -0.015em; line-height: 1.15;">
          {contactInfo.phone.display}
        </div>
        <div class="mt-1 text-[13.5px] text-muted leading-snug">{contactInfo.hours.weekdayLabel}</div>
      </a>

      <a
        href={`mailto:${contactInfo.email}`}
        class="bg-white border border-line rounded-xl p-5 no-underline text-ink block"
      >
        <div class="flex items-center gap-3 mb-1.5">
          <span class="w-8 h-8 rounded-md bg-accent/15 text-accent inline-flex items-center justify-center">
            <Icon name="mail" size={16} stroke={1.7} />
          </span>
          <span class="font-mono text-[11px] text-muted tracking-mono-eyebrow uppercase">Email</span>
          <Icon name="arrowSm" size={14} class="ml-auto text-muted" />
        </div>
        <div class="font-serif font-medium text-ink" style="font-size: 22px; letter-spacing: -0.015em; line-height: 1.15;">
          {contactInfo.email}
        </div>
        <div class="mt-1 text-[13.5px] text-muted leading-snug">Tickets, billing, general — all in one inbox</div>
      </a>

      <div class="bg-white border border-line rounded-xl p-5">
        <div class="flex items-center gap-3 mb-1.5">
          <span class="w-8 h-8 rounded-md bg-accent/15 text-accent inline-flex items-center justify-center">
            <Icon name="compass" size={16} stroke={1.7} />
          </span>
          <span class="font-mono text-[11px] text-muted tracking-mono-eyebrow uppercase">Service area</span>
        </div>
        <div class="font-serif font-medium text-ink" style="font-size: 22px; letter-spacing: -0.015em; line-height: 1.15;">
          {contactInfo.address.city}, {contactInfo.address.state}
        </div>
        <div class="mt-1 text-[13.5px] text-muted leading-snug">{contactInfo.serviceAreaSub}</div>
      </div>

      {block.existingClientPanel && (
        <a
          href={block.existingClientPanel.href}
          class="bg-white border border-line rounded-xl p-5 no-underline text-ink block"
        >
          <div class="flex items-center gap-3 mb-1.5">
            <span class="w-8 h-8 rounded-md bg-accent/15 text-accent inline-flex items-center justify-center">
              <Icon name="users" size={16} stroke={1.7} />
            </span>
            <span class="font-mono text-[11px] text-muted tracking-mono-eyebrow uppercase">{block.existingClientPanel.label}</span>
            <Icon name="arrowSm" size={14} class="ml-auto text-muted" />
          </div>
          <div class="font-serif font-medium text-ink" style="font-size: 22px; letter-spacing: -0.015em; line-height: 1.15;">
            {block.existingClientPanel.primary}
          </div>
          <div class="mt-1 text-[13.5px] text-muted leading-snug">{block.existingClientPanel.sub}</div>
        </a>
      )}

      <!-- Hours table -->
      <div class="bg-bg-alt border border-line rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <span class="inline-flex items-center gap-2 font-semibold text-ink">
            <Icon name="chevron" size={16} class="text-accent" /> Hours
          </span>
        </div>
        <div class="text-[14px]">
          <div class="py-2 border-b border-line-soft text-ink">
            {contactInfo.hours.weekdayLabel}
          </div>
          <div class="flex justify-between py-2 border-b border-line-soft">
            <span class="text-muted">Saturday</span>
            <span class="text-ink">Emergency only</span>
          </div>
          <div class="flex justify-between py-2 border-b border-line-soft">
            <span class="text-muted">Sunday</span>
            <span class="text-ink">Emergency only</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-muted">Managed clients</span>
            <span class="text-ink">24/7</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Client-side: swap form/success when URL has ?submitted=true -->
<script is:inline>
  (function () {
    var params = new URLSearchParams(window.location.search);
    if (params.get("submitted") === "true") {
      var form = document.getElementById("contact-form-container");
      var success = document.getElementById("contact-success-container");
      if (form && success) {
        form.style.display = "none";
        success.style.display = "";
        // Replace state so refreshing/back-button doesn't re-show success.
        try {
          window.history.replaceState({}, "", window.location.pathname);
        } catch (_) { /* ignore */ }
      }
    }
  })();
</script>
