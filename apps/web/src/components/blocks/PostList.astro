---
import type { PostListBlock } from "../../lib/sanity/types";
import BlogFeaturedPost from "../blog/BlogFeaturedPost.astro";
import BlogPostCard from "../blog/BlogPostCard.astro";
import { getAllPosts } from "../../lib/sanity/client";

interface Props {
  block: PostListBlock;
}

const { block } = Astro.props;
const posts = await getAllPosts();

const [featured, ...rest] = posts;

// No category filter chips here: filtering is a /blog-only affordance backed by
// route-based category pages (BlogFilterChips navigates to /blog/category/...).
// As a generic block this can sit on any page, so it just renders the posts.
---

<section class="bg-bg px-5 md:px-10 py-12">
  <div class="max-w-content mx-auto">
    {featured && <BlogFeaturedPost post={featured} />}

    {rest.length > 0 && (
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        {rest.map((p) => <BlogPostCard post={p} />)}
      </div>
    )}

    {posts.length === 0 && (
      <div class="text-center py-12 text-muted">
        {block.emptyStateMessage}
      </div>
    )}
  </div>
</section>
