---
import type { SwitchingHeroBlock } from "../../lib/sanity/types";
import HeadlineRichText from "../HeadlineRichText.astro";
import Icon from "../Icon.astro";

interface Props {
  block: SwitchingHeroBlock;
}

const { block } = Astro.props;
---

<section class="bg-dark text-dark-text px-10 pt-18 pb-0 relative overflow-hidden">
  <!-- radial glow -->
  <div
    class="absolute pointer-events-none"
    style="top: -160px; right: -120px; width: 540px; height: 540px; background: radial-gradient(circle, rgb(220 38 38 / 0.2), transparent 70%);"
  ></div>

  <div class="max-w-content mx-auto relative">
    <div class="grid grid-cols-1 md:grid-cols-[1.4fr_1fr] gap-14 items-end">
      <div>
        <div class="inline-flex items-center gap-2.5 font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-5.5">
          <span class="inline-block bg-accent" style="width: 18px; height: 1px;"></span>
          ◆ {block.eyebrow}
        </div>
        <h1
          class="font-serif font-medium text-dark-text m-0 tracking-display-tight"
          style="font-size: 84px; line-height: 0.96; text-wrap: balance;"
        >
          <HeadlineRichText value={block.title} />
        </h1>
        <p class="mt-5.5 text-dark-muted text-[18.5px] leading-snug max-w-[600px]">
          {block.deck}
        </p>
        <div class="mt-7 flex gap-3 items-center flex-wrap">
          <a
            href={block.ctaPrimaryHref}
            class="bg-accent text-white font-semibold rounded-md inline-flex items-center justify-center gap-2.5 no-underline shadow-button-accent"
            style="padding: 16px 26px; font-size: 16px;"
          >
            {block.ctaPrimaryLabel}
            <Icon name="arrow" size={16} />
          </a>
          <a
            href={block.ctaSecondaryHref}
            class="text-dark-text no-underline font-medium rounded-md border border-dark-line"
            style="padding: 16px 22px; font-size: 15.5px;"
          >
            {block.ctaSecondaryLabel}
          </a>
        </div>
      </div>

      <!-- deal card -->
      <div
        class="border border-dark-line rounded-xl p-7"
        style="background: rgba(255,255,255,0.04);"
      >
        <div class="font-mono text-meta text-dark-muted tracking-mono-eyebrow uppercase mb-4.5">
          ◇ {block.dealCard.eyebrow}
        </div>
        <ul class="m-0 p-0 list-none flex flex-col gap-0">
          {block.dealCard.rows.map((row, i) => (
            <li
              class={`flex items-center justify-between py-3 text-[14.5px] text-dark-text ${
                i === 0 ? "" : "border-t border-dark-line"
              }`}
            >
              <span class="inline-flex items-center gap-2.5">
                <span class="text-accent"><Icon name="check" size={14} stroke={2} /></span>
                {row.label}
              </span>
              <span class="font-mono text-[11px] text-dark-muted tracking-mono-eyebrow uppercase">
                {row.value}
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- fact sheet stat strip -->
    <div class="mt-18 pt-9 pb-18 border-t border-dark-line">
      <div class="flex items-baseline justify-between mb-7 flex-wrap gap-3">
        <div class="font-mono text-meta text-dark-muted tracking-mono-eyebrow uppercase">
          ◇ {block.factSheetLabel}
        </div>
        <div class="inline-flex items-center gap-2 font-mono text-meta text-dark-muted tracking-mono-eyebrow uppercase">
          <span class="w-2 h-2 rounded-full bg-[#22c55e] inline-block"></span>
          {block.liveDotLabel}
        </div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {block.stats.map((s, i) => (
          <div class={i === 0 ? "" : "md:pl-7 md:border-l md:border-dark-line"}>
            <div
              class="font-serif font-medium text-dark-text"
              style="font-size: 64px; letter-spacing: -0.03em; line-height: 1; font-variant-numeric: tabular-nums;"
            >
              {s.k}
            </div>
            <div class="mt-3 font-mono text-[11px] text-dark-muted tracking-[1px] uppercase">
              {s.v}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
