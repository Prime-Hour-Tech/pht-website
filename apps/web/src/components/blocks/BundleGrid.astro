---
import type { BundleGridBlock } from "../../lib/sanity/types";
import HeadlineRichText from "../HeadlineRichText.astro";
import Icon from "../Icon.astro";

interface Props {
  block: BundleGridBlock;
}

const { block } = Astro.props;
---

<section class="bg-bg px-10 py-22 pt-8">
  <div class="max-w-content mx-auto">
    <div class="flex items-baseline justify-between gap-4 flex-wrap mb-7">
      <div>
        <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-3">
          ◆ {block.eyebrow}
        </div>
        <h2
          class="font-serif font-medium text-ink m-0 tracking-display-tight"
          style="font-size: 44px; line-height: 1.05;"
        >
          <HeadlineRichText value={block.heading} />
        </h2>
      </div>
      {block.secondaryLinkLabel && block.secondaryLinkHref && (
        <a
          href={block.secondaryLinkHref}
          class="text-accent no-underline font-semibold text-[14px]"
        >
          {block.secondaryLinkLabel}
        </a>
      )}
    </div>

    <p class="mb-8 text-muted text-body-md leading-body max-w-[640px]">{block.deck}</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
      {block.tiles.map((tile) => (
        <div class="bg-bg border border-line rounded-xl p-7 flex flex-col min-h-[200px]">
          <h3
            class="font-serif font-medium text-ink m-0"
            style="font-size: 24px; letter-spacing: -0.02em; line-height: 1.05;"
          >
            {tile.name}
          </h3>
          <p class="mt-3 text-muted text-[14.5px] leading-body">{tile.descriptor}</p>
          <p class="mt-auto pt-4 font-mono text-[11px] text-muted tracking-mono-eyebrow uppercase border-t border-line-soft">
            {tile.includesLine}
          </p>
        </div>
      ))}
    </div>

    <div class="mt-8 flex justify-end">
      <a
        href={block.footerLinkHref}
        class="text-accent no-underline font-semibold text-[14px] inline-flex items-center gap-1.5"
      >
        {block.footerLinkLabel}
        <Icon name="arrowSm" size={13} />
      </a>
    </div>
  </div>
</section>
