---
import type { NumbersStripBlock } from "../../lib/sanity/types";

interface Props {
  block: NumbersStripBlock;
}

const { block } = Astro.props;
---

<section class="bg-bg-alt py-16 px-10 border-y border-line">
  <div class="max-w-content mx-auto grid grid-cols-2 md:grid-cols-4 gap-6">
    {block.stats.map((s) => (
      <div>
        <div
          class="font-serif font-medium text-ink"
          style="font-size: 56px; letter-spacing: -0.025em; line-height: 1; font-variant-numeric: tabular-nums;"
        >
          {s.k}
        </div>
        <div class="mt-2.5 font-mono text-[11px] text-muted tracking-mono-eyebrow uppercase">
          {s.v}
        </div>
      </div>
    ))}
  </div>
</section>
