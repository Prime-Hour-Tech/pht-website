---
import type { PricingTiersBlock, PricingTier } from "../../lib/sanity/types";
import HeadlineRichText from "../HeadlineRichText.astro";
import Icon from "../Icon.astro";

interface Props {
  block: PricingTiersBlock;
}

const { block } = Astro.props;

// Render in display order. Standard is always the featured (middle) card.
const tierEntries: Array<{ key: "essentials" | "standard" | "premier"; name: string; tier: PricingTier; featured: boolean }> = [
  { key: "essentials", name: "Essentials", tier: block.essentials, featured: false },
  { key: "standard",   name: "Standard",   tier: block.standard,   featured: true  },
  { key: "premier",    name: "Premier",    tier: block.premier,    featured: false },
];
---

<section class="bg-bg-alt px-10 py-20 border-y border-line">
  <div class="max-w-content mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-end mb-11">
      <div>
        <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-3">
          ◆ {block.eyebrow}
        </div>
        <h2
          class="font-serif font-medium text-ink m-0 tracking-display-tight"
          style="font-size: 44px; line-height: 1.05; text-wrap: balance;"
        >
          <HeadlineRichText value={block.heading} />
        </h2>
      </div>
      <p class="m-0 text-muted text-body-md leading-body max-w-[520px]">{block.deck}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-stretch">
      {tierEntries.map(({ name, tier, featured }) => (
        <div
          class={`rounded-xl p-8 flex flex-col relative overflow-hidden ${
            featured
              ? "bg-dark text-dark-text border border-dark-line shadow-button-accent"
              : "bg-bg text-ink border border-line"
          }`}
        >
          {featured && (
            <div
              class="absolute pointer-events-none"
              style="top: -120px; right: -80px; width: 320px; height: 320px; background: radial-gradient(circle, rgb(220 38 38 / 0.2), transparent 70%);"
            ></div>
          )}

          <div class="flex items-center justify-between mb-4.5 relative">
            <span
              class={`font-mono text-meta tracking-mono-eyebrow uppercase ${featured ? "text-accent" : "text-muted"}`}
            >
              {tier.tag}
            </span>
            {tier.flagLabel && (
              <span
                class="font-mono text-[10px] text-accent tracking-mono-eyebrow uppercase border border-accent/40 rounded-sm bg-accent/10"
                style="padding: 3px 8px;"
              >
                {tier.flagLabel}
              </span>
            )}
          </div>

          <h3
            class={`font-serif font-medium m-0 relative ${featured ? "text-dark-text" : "text-ink"}`}
            style="font-size: 32px; letter-spacing: -0.02em; line-height: 1.05;"
          >
            {name}
          </h3>

          <div class="mt-4.5 flex items-baseline gap-2 relative">
            <span
              class={`font-serif font-medium ${featured ? "text-dark-text" : "text-ink"}`}
              style="font-size: 64px; letter-spacing: -0.035em; line-height: 1; font-variant-numeric: tabular-nums;"
            >
              ${tier.price}
            </span>
            <span
              class={`font-mono text-meta tracking-mono-eyebrow uppercase ${featured ? "text-dark-muted" : "text-muted"}`}
            >
              / seat / mo
            </span>
          </div>

          <p
            class={`mt-3.5 text-[14.5px] leading-body max-w-[320px] relative ${featured ? "text-dark-muted" : "text-muted"}`}
          >
            {tier.tagline}
          </p>

          <div
            class={`mt-6 mb-4.5 h-px relative ${featured ? "bg-dark-line" : "bg-line"}`}
          ></div>

          <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-3.5 relative">
            ◇ {tier.includesHead}
          </div>

          <ul class="m-0 p-0 list-none flex flex-col gap-0 flex-1 relative">
            {tier.bullets.map((b, i) => (
              <li
                class={`grid grid-cols-[20px_1fr] gap-3 py-2.5 text-[14px] leading-snug ${
                  i === 0 ? "" : (featured ? "border-t border-dark-line" : "border-t border-line-soft")
                } ${featured ? "text-dark-text" : "text-ink"}`}
              >
                <span class="text-accent mt-0.5"><Icon name="check" size={14} stroke={2} /></span>
                <span>{b}</span>
              </li>
            ))}
          </ul>

          <a
            href={tier.ctaHref}
            class={`mt-6 w-full rounded-md font-semibold inline-flex items-center justify-center gap-2.5 no-underline relative ${
              featured
                ? "bg-accent text-white shadow-button-accent border border-accent"
                : "bg-bg text-ink border border-line"
            }`}
            style="padding: 14px 20px; font-size: 14.5px;"
          >
            {tier.ctaLabel}
            <Icon name="arrowSm" size={14} />
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
