---
import type { IndustriesContentBlock } from "../../lib/sanity/types";
import Icon from "../Icon.astro";

interface Props {
  block: IndustriesContentBlock;
}

const { block } = Astro.props;
const totalLabel = String(block.verticals.length).padStart(2, "0");
---

<!-- Sticky jump nav -->
<section class="bg-bg-alt border-y border-line sticky top-0 z-10 py-6 px-10">
  <div class="max-w-content mx-auto flex items-center gap-3 flex-wrap">
    <span class="font-mono text-[11px] text-muted tracking-mono-eyebrow uppercase">
      {block.jumpLabel}
    </span>
    {block.verticals.map((v) => (
      <a
        href={`#${v.id}`}
        class="inline-flex items-center gap-2 px-3.5 py-2 rounded-full border border-line bg-bg text-ink no-underline text-[13.5px] font-medium hover:border-accent/40 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
      >
        <Icon name={v.iconName} size={13} />
        {v.name}
      </a>
    ))}
  </div>
</section>

<!-- Vertical sections -->
{block.verticals.map((v, i) => (
  <section
    id={v.id}
    class={`scroll-mt-24 py-24 px-10 border-b border-line ${i % 2 === 1 ? "bg-bg-alt" : "bg-bg"}`}
  >
    <div class="max-w-content mx-auto">
      <div class="inline-flex items-center gap-3.5 mb-6">
        <span
          class="w-12 h-12 rounded-xl bg-accent/10 text-accent border border-accent/20 inline-flex items-center justify-center"
        >
          <Icon name={v.iconName} size={22} />
        </span>
        <div>
          <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase">
            ◆ Vertical · {String(i + 1).padStart(2, "0")} of {totalLabel}
          </div>
          <h2
            class="font-serif font-medium text-ink m-0 mt-1.5"
            style="font-size: 52px; line-height: 1.02; letter-spacing: -0.025em; text-wrap: balance;"
          >
            {v.name}
          </h2>
          <div class="mt-1.5 font-mono text-[12px] text-muted tracking-[0.6px] uppercase">
            {v.sub}
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-[1.3fr_1fr] gap-14 items-start mt-8">
        <div>
          <p class="m-0 text-muted text-[17.5px] leading-body max-w-[620px]">{v.intro}</p>
          <ul class="mt-6 p-0 list-none flex flex-col gap-0">
            {v.bullets.map((b) => (
              <li
                class="flex gap-3.5 text-ink text-[15.5px] leading-snug py-3.5 border-b border-line-soft"
              >
                <span class="text-accent mt-1"><Icon name="check" size={16} stroke={2} /></span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>

        <aside
          class={`${i % 2 === 1 ? "bg-bg" : "bg-bg-alt"} border border-line rounded-xl p-6`}
        >
          <div class="font-mono text-[11px] text-accent tracking-mono-eyebrow uppercase mb-4">
            ◇ Who in this category
          </div>
          <ul class="m-0 p-0 list-none grid grid-cols-1 sm:grid-cols-2 gap-0">
            {v.examples.map((e) => (
              <li
                class="py-2.5 border-b border-line-soft text-[14px] text-ink font-mono tracking-[0.3px]"
              >
                — {e}
              </li>
            ))}
          </ul>
        </aside>
      </div>
    </div>
  </section>
))}
