---
import type { SwitchingHandleBlock } from "../../lib/sanity/types";
import HeadlineRichText from "../HeadlineRichText.astro";
import Icon from "../Icon.astro";

interface Props {
  block: SwitchingHandleBlock;
}

const { block } = Astro.props;
---

<section class="bg-bg px-5 md:px-10 py-22 border-b border-line">
  <div class="max-w-content mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-[0.9fr_1.1fr] gap-16 items-end mb-12">
      <div>
        <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-4">
          ◆ {block.eyebrow}
        </div>
        <h2
          class="font-serif font-medium text-ink m-0 tracking-display-tight"
          style="font-size: clamp(32px, 7vw, 52px); line-height: 1.02; text-wrap: balance;"
        >
          <HeadlineRichText value={block.title} />
        </h2>
      </div>
      <p class="m-0 text-muted text-body-lg leading-body">{block.deck}</p>
    </div>

    <div class="flex flex-col gap-0">
      {block.items.map((item, i) => (
        <div
          class={`grid grid-cols-1 md:grid-cols-2 gap-0 ${
            i === 0 ? "" : "border-t border-line"
          }`}
        >
          <!-- Pain column -->
          <div class="py-6 pr-0 md:pr-8 md:border-r md:border-line flex flex-col gap-2.5">
            <div class="font-mono text-[10.5px] text-muted tracking-mono-eyebrow uppercase">
              ◇ The friction
            </div>
            <h3
              class="font-serif font-medium text-ink m-0"
              style="font-size: 20px; letter-spacing: -0.015em; line-height: 1.2;"
            >
              {item.painLabel}
            </h3>
            <p class="m-0 text-muted text-[14.5px] leading-body">{item.painBody}</p>
          </div>

          <!-- We-handle column -->
          <div class="py-6 md:pl-8 flex flex-col gap-2.5">
            <div class="font-mono text-[10.5px] text-accent tracking-mono-eyebrow uppercase inline-flex items-center gap-1.5">
              <Icon name="check" size={11} stroke={2.5} />
              We handle it
            </div>
            <h3
              class="font-serif font-medium text-ink m-0"
              style="font-size: 20px; letter-spacing: -0.015em; line-height: 1.2;"
            >
              {item.weHandleLabel}
            </h3>
            <p class="m-0 text-muted text-[14.5px] leading-body">{item.weHandleBody}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
