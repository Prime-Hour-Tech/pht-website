---
import type { PageBlock, ContactInfo } from "../../lib/sanity/types";
import DarkNumbersHero from "./DarkNumbersHero.astro";
import TrustStrip from "./TrustStrip.astro";
import TeamGrid from "./TeamGrid.astro";
import Headaches from "./Headaches.astro";
import Savings from "./Savings.astro";
import ServicesList from "./ServicesList.astro";
import Beliefs from "./Beliefs.astro";
import CtaCard from "./CtaCard.astro";
import PageHero from "./PageHero.astro";
import OriginPhoto from "./OriginPhoto.astro";
import StoryThreeCol from "./StoryThreeCol.astro";
import NumbersStrip from "./NumbersStrip.astro";
import MilestonesTimeline from "./MilestonesTimeline.astro";
import OfficeCulture from "./OfficeCulture.astro";
import IndustriesContent from "./IndustriesContent.astro";
import IndustriesDontSeeYours from "./IndustriesDontSeeYours.astro";
import ContactBody from "./ContactBody.astro";
import PostList from "./PostList.astro";
import ServicesIndexHero from "./ServicesIndexHero.astro";
import PricingTiers from "./PricingTiers.astro";
import BundleGrid from "./BundleGrid.astro";
import ProcessStrip from "./ProcessStrip.astro";
import IndustryCrosslink from "./IndustryCrosslink.astro";
import SwitchingHero from "./SwitchingHero.astro";
import SwitchingReasons from "./SwitchingReasons.astro";
import SwitchingTimeline from "./SwitchingTimeline.astro";
import SwitchingHandle from "./SwitchingHandle.astro";
import SwitchingCompare from "./SwitchingCompare.astro";
import SwitchingPromises from "./SwitchingPromises.astro";
import SwitchingTestimonial from "./SwitchingTestimonial.astro";
import FaqList from "./FaqList.astro";

interface Props {
  block: PageBlock;
  contactInfo: ContactInfo;
}

const { block, contactInfo } = Astro.props;
---

{block._type === "darkNumbersHero" && <DarkNumbersHero block={block} />}
{block._type === "trustStrip"      && <TrustStrip      block={block} />}
{block._type === "teamGrid"        && <TeamGrid        block={block} />}
{block._type === "headaches"       && <Headaches       block={block} />}
{block._type === "savings"         && <Savings         block={block} />}
{block._type === "servicesList"    && <ServicesList    block={block} />}
{block._type === "beliefs"         && <Beliefs         block={block} />}
{block._type === "ctaCard"         && <CtaCard         block={block} contactInfo={contactInfo} />}
{block._type === "pageHero"        && <PageHero        block={block} />}
{block._type === "originPhoto"     && <OriginPhoto     block={block} />}
{block._type === "storyThreeCol"   && <StoryThreeCol   block={block} />}
{block._type === "numbersStrip"    && <NumbersStrip    block={block} />}
{block._type === "milestonesTimeline" && <MilestonesTimeline block={block} />}
{block._type === "officeCulture"      && <OfficeCulture      block={block} />}
{block._type === "industriesContent" && <IndustriesContent block={block} />}
{block._type === "industriesDontSeeYours" && <IndustriesDontSeeYours block={block} />}
{block._type === "contactBody"     && <ContactBody     block={block} />}
{block._type === "postList"            && <PostList            block={block} />}
{block._type === "servicesIndexHero"   && <ServicesIndexHero   block={block} />}
{block._type === "pricingTiers"        && <PricingTiers        block={block} />}
{block._type === "bundleGrid"          && <BundleGrid          block={block} />}
{block._type === "processStrip"        && <ProcessStrip        block={block} />}
{block._type === "industryCrosslink"   && <IndustryCrosslink   block={block} />}
{block._type === "switchingHero"       && <SwitchingHero       block={block} />}
{block._type === "switchingReasons"    && <SwitchingReasons    block={block} />}
{block._type === "switchingTimeline"   && <SwitchingTimeline   block={block} />}
{block._type === "switchingHandle"     && <SwitchingHandle     block={block} />}
{block._type === "switchingCompare"    && <SwitchingCompare    block={block} />}
{block._type === "switchingPromises"   && <SwitchingPromises   block={block} />}
{block._type === "switchingTestimonial"&& <SwitchingTestimonial block={block} />}
{block._type === "faqList"             && <FaqList             block={block} />}
