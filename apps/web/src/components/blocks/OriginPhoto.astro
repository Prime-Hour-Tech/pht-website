---
import type { OriginPhotoBlock } from "../../lib/sanity/types";
import { urlFor } from "../../lib/sanity/imageUrl";

interface Props {
  block: OriginPhotoBlock;
}

const { block } = Astro.props;
const aspectStyle = `aspect-ratio: ${block.aspectRatio};`;
const imageUrl = urlFor(block.image).width(1920).fit("max").url();
---

<section class="bg-bg px-10 pb-24">
  <div class="max-w-content mx-auto relative">
    <div
      class="bg-bg-alt rounded-xl overflow-hidden"
      style={aspectStyle}
    >
      <img
        src={imageUrl}
        alt={block.image.alt}
        class="w-full h-full object-cover"
      />
    </div>
    <div
      class="absolute left-6 bottom-6 max-w-[420px] rounded-xl p-6 text-dark-text border border-dark-line"
      style="background: rgba(15,17,21,0.92); backdrop-filter: blur(10px);"
    >
      <div class="font-mono text-[10.5px] text-dark-muted tracking-mono-eyebrow uppercase mb-2">
        {block.caption.eyebrowLabel}
      </div>
      <p class="font-serif italic text-[20px] leading-snug m-0">
        "{block.caption.quote}"
      </p>
      <div class="mt-2 font-mono text-[10.5px] text-dark-muted uppercase" style="letter-spacing: 0.6px;">
        {block.caption.attribution}
      </div>
    </div>
  </div>
</section>
