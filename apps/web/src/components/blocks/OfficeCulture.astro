---
import type { OfficeCultureBlock } from "../../lib/sanity/types";
import HeadlineRichText from "../HeadlineRichText.astro";
import Icon from "../Icon.astro";
import { urlForResponsive } from "../../lib/sanity/imageUrl";

interface Props {
  block: OfficeCultureBlock;
}

const { block } = Astro.props;
const aspectStyle = `aspect-ratio: ${block.aspectRatio};`;
const img = block.image
  ? urlForResponsive(block.image, { widths: [480, 768, 1024, 1200] })
  : null;
---

<section class="bg-bg py-24 px-5 md:px-10">
  <div class="max-w-content mx-auto grid grid-cols-1 md:grid-cols-2 gap-14 items-center">
    <div class="bg-bg-alt rounded-xl overflow-hidden" style={aspectStyle}>
      {img ? (
        <img
          src={img.src}
          srcset={img.srcset}
          sizes="(min-width: 1280px) 600px, (min-width: 768px) 48vw, 100vw"
          width={img.width}
          alt={block.image!.alt}
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="w-full h-full bg-bg border border-line" aria-hidden="true"></div>
      )}
    </div>
    <div>
      <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-3.5">
        ◆ {block.eyebrow}
      </div>
      <h2
        class="font-serif font-medium text-ink m-0"
        style="font-size: clamp(30px, 6vw, 44px); line-height: 1.05; letter-spacing: -0.025em; text-wrap: balance;"
      >
        <HeadlineRichText value={block.heading} />
      </h2>
      <p class="mt-4.5 text-muted text-[16.5px] leading-body max-w-[480px]">{block.body}</p>
      <ul class="mt-6 p-0 list-none flex flex-col gap-2.5">
        {(block.bullets ?? []).filter(Boolean).map((b) => (
          <li class="flex gap-3 text-ink text-[15.5px]">
            <span class="text-accent mt-1"><Icon name="check" size={14} stroke={2} /></span>
            <span>{b}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
