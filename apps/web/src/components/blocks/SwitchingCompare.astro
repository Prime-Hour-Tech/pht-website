---
import type { SwitchingCompareBlock } from "../../lib/sanity/types";
import HeadlineRichText from "../HeadlineRichText.astro";
import Icon from "../Icon.astro";
import Logomark from "../Logomark.astro";

interface Props {
  block: SwitchingCompareBlock;
}

const { block } = Astro.props;
---

<section class="bg-bg-alt px-10 py-22 border-b border-line">
  <div class="max-w-content mx-auto">
    <div class="mb-10">
      <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-3.5">
        ◆ {block.eyebrow}
      </div>
      <h2
        class="font-serif font-medium text-ink m-0 tracking-display-tight max-w-[720px]"
        style="font-size: 52px; line-height: 1.02; text-wrap: balance;"
      >
        <HeadlineRichText value={block.title} />
      </h2>
    </div>

    <div class="bg-bg border border-line rounded-xl overflow-hidden">
      <div
        class="grid grid-cols-[1.1fr_1.4fr_1.4fr] px-7 py-5 border-b border-line bg-bg-alt font-mono text-meta tracking-mono-eyebrow uppercase"
      >
        <div class="text-muted">Aspect</div>
        <div class="text-muted">{block.themHeader}</div>
        <div class="text-accent inline-flex items-center gap-2">
          <span class="text-accent"><Logomark size={16} bg="transparent" /></span>
          {block.usHeader}
        </div>
      </div>

      {block.rows.map((row, i) => (
        <div
          class={`grid grid-cols-[1.1fr_1.4fr_1.4fr] px-7 py-4.5 items-center text-[15px] ${
            i === block.rows.length - 1 ? "" : "border-b border-line-soft"
          }`}
        >
          <div class="font-semibold text-ink">{row.topic}</div>
          <div class="text-muted inline-flex items-center gap-2.5">
            <span
              class="w-4.5 h-4.5 rounded-full inline-flex items-center justify-center bg-bg-alt border border-line text-muted text-[11px]"
            >
              —
            </span>
            {row.them}
          </div>
          <div class="text-ink font-medium inline-flex items-center gap-2.5">
            <span
              class="w-4.5 h-4.5 rounded-full inline-flex items-center justify-center bg-accent/10 text-accent border border-accent/40"
            >
              <Icon name="check" size={11} stroke={2.6} />
            </span>
            {row.us}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
