---
import type { StoryThreeColBlock } from "../../lib/sanity/types";
import HeadlineRichText from "../HeadlineRichText.astro";

interface Props {
  block: StoryThreeColBlock;
}

const { block } = Astro.props;
---

<section class="bg-bg px-5 md:px-10 pb-24">
  <div class="max-w-content mx-auto">
    <div class="text-center mb-14">
      <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-6">
        ◆ {block.eyebrow}
      </div>
      <h2
        class="font-serif font-medium text-ink m-0 mx-auto max-w-[820px] tracking-display"
        style="font-size: clamp(34px, 7vw, 56px); line-height: 1; text-wrap: balance;"
      >
        <HeadlineRichText value={block.heading} />
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      {block.columns.map((c) => (
        <div>
          <div class="font-mono text-[11px] text-muted tracking-mono-eyebrow uppercase mb-3">
            {c.eyebrow}
          </div>
          <h3
            class="font-serif font-medium text-ink m-0"
            style="font-size: 26px; line-height: 1.18; letter-spacing: -0.015em; text-wrap: balance;"
          >
            {c.heading}
          </h3>
          <p class="mt-3.5 text-muted text-[15.5px] leading-body">{c.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
