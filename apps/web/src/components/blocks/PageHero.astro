---
import type { PageHeroBlock } from "../../lib/sanity/types";
import HeadlineRichText from "../HeadlineRichText.astro";

interface Props {
  block: PageHeroBlock;
}

const { block } = Astro.props;
const isTwoCol = block.deck.length === 2;
---

<section class="bg-bg py-20 px-5 md:px-10">
  <div class={`max-w-content mx-auto grid ${isTwoCol ? "grid-cols-1 md:grid-cols-[1.5fr_1fr]" : "grid-cols-1"} gap-16 items-end`}>
    <div>
      <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-4">
        ◆ {block.eyebrow}
      </div>
      <h1
        class="font-serif font-medium text-ink m-0 tracking-display-tight"
        style="font-size: clamp(40px, 11vw, 104px); line-height: 0.94; text-wrap: balance;"
      >
        <HeadlineRichText value={block.headline} />
      </h1>
    </div>
    <div class={isTwoCol ? "flex flex-col gap-3.5 max-w-[480px]" : "mt-5 max-w-[640px] flex flex-col gap-3.5"}>
      {block.deck.map((paragraph) => (
        <p class="m-0 text-muted text-body-lg leading-snug">{paragraph}</p>
      ))}
    </div>
  </div>
</section>
