---
import type {
  ContactInfo,
  Navigation,
  SiteSettings,
} from "../../lib/sanity/types";
import { urlFor } from "../../lib/sanity/imageUrl";

interface Props {
  siteSettings: SiteSettings;
  navigation: Navigation;
  contactInfo: ContactInfo;
}

const { siteSettings, navigation, contactInfo } = Astro.props;
const pathname = Astro.url.pathname;
const logoDarkUrl = siteSettings.logoDark
  ? urlFor(siteSettings.logoDark).width(72).height(72).fit("max").url()
  : null;

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/";
  // Trailing-slash insensitive prefix match
  const trimmed = href.endsWith("/") ? href.slice(0, -1) : href;
  return pathname === trimmed || pathname.startsWith(trimmed + "/");
}
---

<nav
  aria-label="Main navigation"
  class="bg-bg border-b border-line sticky top-0 z-10"
>
  <div
    class="max-w-content mx-auto px-4 md:px-10 py-4.5 flex items-center gap-10"
  >
    <!-- Brand -->
    <a href="/" class="inline-flex items-center gap-3.5 no-underline text-ink">
      {logoDarkUrl ? (
        <img
          src={logoDarkUrl}
          alt={siteSettings.logoDark!.alt}
          width="36"
          height="36"
          class="size-9 object-contain"
        />
      ) : (
        <div class="size-9 rounded-md bg-accent" aria-hidden="true"></div>
      )}
      <span class="flex flex-col leading-none">
        {/* text-[19px]: intentional - sits between body-lg (18px) and body-xl (21px); no token matches */}
        <span class="font-serif font-semibold text-[19px] tracking-h3">
          {siteSettings.siteName}
        </span>
        <span class="font-mono text-micro text-muted tracking-mono-label uppercase">
          Reliability &amp; Integrity
        </span>
      </span>
    </a>

    <!-- Desktop nav links -->
    <ul class="hidden md:flex list-none p-0 m-0 gap-1.5 text-body-sm">
      {navigation.items.map((item) => {
        const active = isActive(item.href);
        return (
          <li>
            <a
              href={item.href}
              target={item.openInNewTab ? "_blank" : undefined}
              rel={item.openInNewTab ? "noopener noreferrer" : undefined}
              class:list={[
                "px-3.5 py-2.5 no-underline text-ink border-b-2 inline-block",
                active
                  ? "font-semibold border-accent"
                  : "font-medium border-transparent hover:border-line",
              ]}
              aria-current={active ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>

    <!-- Right side -->
    <div class="ml-auto flex items-center gap-3">
      <a
        href={`tel:${contactInfo.phone.dial}`}
        class="hidden md:inline-flex items-center gap-1.5 text-ink text-body-sm font-medium no-underline"
      >
        {contactInfo.phone.display}
      </a>
      <a
        href={navigation.ctaButton.href}
        class="bg-accent text-white font-semibold text-body-sm no-underline rounded-md px-5 py-3 shadow-button-accent inline-flex items-center gap-2"
      >
        {navigation.ctaButton.label}
      </a>

      <button
        type="button"
        class="md:hidden p-2 text-ink"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-drawer"
        data-mobile-toggle
      >
        ☰
      </button>
    </div>
  </div>
</nav>

<!-- Mobile drawer: full-screen slide-down panel -->
<div
  id="mobile-drawer"
  data-mobile-drawer
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile navigation"
  class="md:hidden fixed inset-0 z-50 bg-bg -translate-y-full pointer-events-none transition-transform duration-300 ease-out"
>
  <div class="flex flex-col h-full px-6 py-8">
    <div class="flex items-center justify-between mb-10">
      <span class="font-serif font-semibold text-serif-sm tracking-h3 text-ink">
        {siteSettings.siteName}
      </span>
      <button
        type="button"
        class="p-2 text-ink"
        aria-label="Close menu"
        data-mobile-close
      >
        ✕
      </button>
    </div>
    <ul class="list-none p-0 m-0 flex flex-col gap-2 text-serif-md font-serif">
      {navigation.items.map((item) => (
        <li>
          <a
            href={item.href}
            target={item.openInNewTab ? "_blank" : undefined}
            rel={item.openInNewTab ? "noopener noreferrer" : undefined}
            class="block py-3 no-underline text-ink"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="mt-auto flex flex-col gap-4">
      <a
        href={`tel:${contactInfo.phone.dial}`}
        class="text-body-base text-ink no-underline"
      >
        {contactInfo.phone.display}
      </a>
      <a
        href={navigation.ctaButton.href}
        class="bg-accent text-white font-semibold text-body-base no-underline rounded-md px-6 py-4 shadow-button-accent text-center"
      >
        {navigation.ctaButton.label}
      </a>
    </div>
  </div>
</div>

<script>
  import "../../scripts/mobile-drawer";
</script>
