---
interface Props {
  eyebrow: string;
  title: string;
  lastUpdated: string; // ISO date
}

const { eyebrow, title, lastUpdated } = Astro.props;
const dateText = new Date(lastUpdated).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<section class="bg-bg px-5 md:px-10 pt-16 pb-10">
  <div class="max-w-content mx-auto">
    <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-5">
      ◆ {eyebrow}
    </div>
    <h1
      class="font-serif font-medium text-ink m-0 tracking-display-tight"
      style="font-size: clamp(34px, 9vw, 96px); line-height: 0.98; text-wrap: balance;"
    >
      {title}
    </h1>
    <div class="mt-5 inline-flex items-center gap-2 font-mono text-[12px] text-muted tracking-[0.4px] uppercase border border-line rounded-full px-3 py-1.5">
      Last updated: {dateText}
    </div>
  </div>
</section>
