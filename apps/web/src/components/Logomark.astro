---
// Brand logomark: clock-tick ring with accent-colored "prime hour" tick and "PH" text.
// Ported from design canvas's shared.jsx Logomark. Uses currentColor for stroke so
// callers can recolor by setting `color` (or text-* tailwind classes) on the parent.
//
// `accent` is the color of the prime-hour tick; defaults to the brand red so the
// glyph looks correct without props. `bg` fills the rounded frame; defaults to
// transparent.

interface Props {
  size?: number;
  accent?: string;
  bg?: string;
  class?: string;
}

const { size = 32, accent = "#dc2626", bg = "transparent", class: className = "" } = Astro.props;

// Precompute the 12 clock ticks
const ticks = Array.from({ length: 12 }).map((_, i) => {
  const a = ((i * 30 - 90) * Math.PI) / 180;
  const r1 = 13;
  const r2 = i % 3 === 0 ? 10.5 : 12;
  return {
    x1: 20 + Math.cos(a) * r1,
    y1: 20 + Math.sin(a) * r1,
    x2: 20 + Math.cos(a) * r2,
    y2: 20 + Math.sin(a) * r2,
  };
});
---

<svg
  width={size}
  height={size}
  viewBox="0 0 40 40"
  class={className}
  style="display: block;"
  aria-hidden="true"
>
  <rect
    x="0.5"
    y="0.5"
    width="39"
    height="39"
    rx="6"
    fill={bg}
    stroke="currentColor"
    stroke-opacity=".18"
  />
  <circle
    cx="20"
    cy="20"
    r="13"
    fill="none"
    stroke="currentColor"
    stroke-opacity=".25"
    stroke-width="1"
  />
  {ticks.map((t) => (
    <line
      x1={t.x1}
      y1={t.y1}
      x2={t.x2}
      y2={t.y2}
      stroke="currentColor"
      stroke-opacity=".35"
      stroke-width="1"
    />
  ))}
  <line x1="20" y1="7" x2="20" y2="11" stroke={accent} stroke-width="2.5" stroke-linecap="round" />
  <text
    x="20"
    y="25"
    text-anchor="middle"
    font-family="'Geist Mono', ui-monospace, monospace"
    font-size="11"
    font-weight="700"
    fill="currentColor"
    letter-spacing="0"
  >
    PH
  </text>
</svg>
