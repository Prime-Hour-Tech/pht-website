---
// Icon: single component, name-prop-driven inline SVG.
// Paths transcribed from Lucide and design_handoff_docs/shared.jsx.

import type { IconName } from "../lib/sanity/types";
export type { IconName };

interface Props {
  name: IconName;
  size?: number;
  stroke?: number;
  class?: string;
}

const { name, size = 16, stroke = 1.6, class: className = "" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={stroke}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  {name === "monitor" && (
    <>
      <rect x="3" y="4" width="18" height="13" rx="2" />
      <line x1="8" y1="20" x2="16" y2="20" />
      <line x1="12" y1="17" x2="12" y2="20" />
    </>
  )}
  {name === "shield" && (
    <path d="M12 3l8 3v6c0 4.5-3.2 8.6-8 9-4.8-.4-8-4.5-8-9V6l8-3z" />
  )}
  {name === "cloud" && (
    <path d="M17 18a4 4 0 000-8 6 6 0 00-11.7 1.5A3.5 3.5 0 006 18z" />
  )}
  {name === "server" && (
    <>
      <rect x="3" y="4" width="18" height="7" rx="1.5" />
      <rect x="3" y="13" width="18" height="7" rx="1.5" />
      <line x1="7" y1="7.5" x2="7.01" y2="7.5" />
      <line x1="7" y1="16.5" x2="7.01" y2="16.5" />
    </>
  )}
  {name === "compass" && (
    <>
      <circle cx="12" cy="12" r="9" />
      <polygon points="15.5 8.5 10 10 8.5 15.5 14 14 15.5 8.5" />
    </>
  )}
  {name === "globe" && (
    <>
      <circle cx="12" cy="12" r="9" />
      <line x1="3" y1="12" x2="21" y2="12" />
      <path d="M12 3a14 14 0 010 18M12 3a14 14 0 000 18" />
    </>
  )}
  {name === "arrow" && (
    <>
      <line x1="5" y1="12" x2="19" y2="12" />
      <polyline points="13 6 19 12 13 18" />
    </>
  )}
  {name === "arrowSm" && (
    <>
      <line x1="6" y1="12" x2="18" y2="12" />
      <polyline points="14 7 18 12 14 17" />
    </>
  )}
  {name === "check" && <polyline points="5 12 10 17 19 7" />}
  {name === "phone" && (
    <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.36 1.9.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.34 1.85.57 2.81.7a2 2 0 011.72 2z" />
  )}
  {name === "mail" && (
    <>
      <rect x="3" y="5" width="18" height="14" rx="2" />
      <polyline points="3 7 12 13 21 7" />
    </>
  )}
  {name === "chevron" && <path d="m6 9 6 6 6-6" />}
  {name === "file" && (
    <>
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
      <path d="M14 2v6h6" />
    </>
  )}
  {name === "users" && (
    <>
      <circle cx="9" cy="7" r="4" />
      <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
      <circle cx="17" cy="7" r="3" />
      <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
    </>
  )}
  {name === "spark" && (
    <path d="M12 2l2 7 7 2-7 2-2 7-2-7-7-2 7-2z" />
  )}
  {name === "lock" && (
    <>
      <rect x="3" y="11" width="18" height="11" rx="2" />
      <path d="M7 11V7a5 5 0 0 1 10 0v4" />
    </>
  )}
  {name === "linkedin" && (
    <>
      <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z" />
      <rect x="2" y="9" width="4" height="12" />
      <circle cx="4" cy="4" r="2" />
    </>
  )}
  {name === "x" && (
    <>
      <path d="M18 6L6 18" />
      <path d="M6 6l12 12" />
    </>
  )}
</svg>
