---
import type { PostCategory } from "../../lib/sanity/types";
import { categoryToSlug } from "../../lib/sanity/categories";

interface Props {
  categories: PostCategory[];
  /** Slug of the active category, or "all" on the all-posts route. */
  active: string;
}

const { categories, active } = Astro.props;
const chipBase =
  "inline-flex items-center px-3.5 py-1.5 rounded-full border text-[13.5px] font-medium no-underline";
---

<section class="bg-bg-alt border-y border-line sticky top-0 z-10 py-4 px-5 md:px-10">
  <div class="max-w-content mx-auto flex items-center gap-2 flex-wrap">
    <span class="font-mono text-[11px] text-muted tracking-mono-eyebrow uppercase mr-2">Filter:</span>
    <a href="/blog"
      class:list={[chipBase, active === "all" ? "border-accent text-accent bg-bg" : "border-line text-ink bg-bg"]}>
      All
    </a>
    {categories.map((c) => {
      const slug = categoryToSlug(c);
      return (
        <a href={`/blog/category/${slug}`}
          class:list={[chipBase, active === slug ? "border-accent text-accent bg-bg" : "border-line text-ink bg-bg"]}>
          {c}
        </a>
      );
    })}
  </div>
</section>
