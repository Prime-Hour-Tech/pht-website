---
interface Props {
  currentPage: number;
  lastPage: number;
  /** Page-1 URL has no number suffix, e.g. "/blog" or "/blog/category/cloud". */
  baseUrl: string;
}

const { currentPage, lastPage, baseUrl } = Astro.props;
const href = (n: number) => (n === 1 ? baseUrl : `${baseUrl}/${n}`);
const pages = Array.from({ length: lastPage }, (_, i) => i + 1);
---

{lastPage > 1 && (
  <nav class="flex items-center justify-center gap-2 mt-12" aria-label="Blog pagination">
    {currentPage > 1 && (
      <a href={href(currentPage - 1)} rel="prev"
        class="px-3.5 py-2 rounded-md border border-line text-ink no-underline text-[14px] hover:border-accent">
        ← Prev
      </a>
    )}
    {pages.map((n) => (
      <a href={href(n)} aria-current={n === currentPage ? "page" : undefined}
        class:list={[
          "px-3.5 py-2 rounded-md border text-[14px] no-underline",
          n === currentPage ? "border-accent text-accent" : "border-line text-ink hover:border-accent",
        ]}>
        {n}
      </a>
    ))}
    {currentPage < lastPage && (
      <a href={href(currentPage + 1)} rel="next"
        class="px-3.5 py-2 rounded-md border border-line text-ink no-underline text-[14px] hover:border-accent">
        Next →
      </a>
    )}
  </nav>
)}
