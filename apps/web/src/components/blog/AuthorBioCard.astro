---
import type { PostFull } from "../../lib/sanity/types";
import { urlFor } from "../../lib/sanity/imageUrl";

interface Props {
  author: PostFull["author"];
}

const { author } = Astro.props;
const photoUrl = author.photo
  ? urlFor(author.photo).width(160).height(160).fit("crop").url()
  : null;
---

<section class="bg-bg-alt px-10 py-12 border-y border-line">
  <div class="max-w-[720px] mx-auto flex flex-col sm:flex-row gap-6 items-start">
    {photoUrl ? (
      <img
        src={photoUrl}
        alt={author.photo?.alt ?? author.name}
        class="w-20 h-20 rounded-full object-cover flex-shrink-0"
      />
    ) : (
      <div class="w-20 h-20 rounded-full bg-bg-alt border border-line flex-shrink-0"></div>
    )}
    <div>
      <div class="font-mono text-[11px] text-muted tracking-mono-eyebrow uppercase mb-1.5">
        ◇ Written by
      </div>
      <div
        class="font-serif font-medium text-ink"
        style="font-size: 22px; letter-spacing: -0.015em; line-height: 1.15;"
      >
        {author.name}
      </div>
      <div class="font-mono text-[12px] text-muted tracking-[0.4px] uppercase mt-1">
        {author.role}
      </div>
      <p class="mt-3.5 text-muted text-[15.5px] leading-body m-0">{author.bio}</p>
    </div>
  </div>
</section>
