---
import type { PostCard } from "../../lib/sanity/types";
import { urlFor } from "../../lib/sanity/imageUrl";
import Icon from "../Icon.astro";

interface Props {
  post: PostCard;
}

const { post } = Astro.props;
const coverUrl = urlFor(post.coverImage).width(1200).height(900).fit("crop").url();
const dateText = new Date(post.publishDate).toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a
  href={`/blog/${post.slug}`}
  data-post-card
  data-category={post.category}
  class="bg-bg border border-line rounded-xl no-underline text-ink grid grid-cols-1 md:grid-cols-2 overflow-hidden mb-10 hover:border-accent/40 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
>
  <img src={coverUrl} alt={post.coverImage.alt} class="w-full h-full object-cover aspect-[4/3] md:aspect-auto" />
  <div class="p-8 flex flex-col gap-3.5 justify-center">
    <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase">
      ◆ Featured · {post.category}
    </div>
    <h2
      class="font-serif font-medium text-ink m-0 tracking-display-tight"
      style="font-size: 36px; line-height: 1.1; text-wrap: balance;"
    >
      {post.title}
    </h2>
    <p class="text-muted text-body-lg leading-body m-0">{post.excerpt}</p>
    <div class="font-mono text-[11px] text-muted tracking-[0.4px] uppercase mt-2">
      {post.author.name} · {post.author.role} · {dateText}
    </div>
    <span class="inline-flex items-center gap-1.5 text-accent font-semibold text-[14.5px] mt-1">
      Read <Icon name="arrowSm" size={14} />
    </span>
  </div>
</a>
