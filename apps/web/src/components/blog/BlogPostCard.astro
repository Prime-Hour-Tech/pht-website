---
import type { PostCard } from "../../lib/sanity/types";
import { urlFor } from "../../lib/sanity/imageUrl";

interface Props {
  post: PostCard;
}

const { post } = Astro.props;
const coverUrl = urlFor(post.coverImage).width(640).height(480).fit("crop").url();
const dateText = new Date(post.publishDate).toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a
  href={`/blog/${post.slug}`}
  data-post-card
  data-category={post.category}
  class="bg-bg border border-line rounded-xl no-underline text-ink flex flex-col overflow-hidden hover:border-accent/40 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
>
  <img src={coverUrl} alt={post.coverImage.alt} class="w-full aspect-[4/3] object-cover" />
  <div class="p-5 flex flex-col gap-2.5">
    <div class="font-mono text-[11px] text-accent tracking-mono-eyebrow uppercase">
      {post.category}
    </div>
    <h3
      class="font-serif font-medium text-ink m-0"
      style="font-size: 22px; line-height: 1.2; letter-spacing: -0.015em; text-wrap: balance;"
    >
      {post.title}
    </h3>
    <p class="text-muted text-[14.5px] leading-snug m-0">{post.excerpt}</p>
    <div class="mt-1.5 font-mono text-[11px] text-muted tracking-[0.4px] uppercase">
      {post.author.name} · {dateText}
    </div>
  </div>
</a>
