---
import type { BlogIndexPage } from "../../lib/sanity/types";
import HeadlineRichText from "../HeadlineRichText.astro";

interface Props {
  page: BlogIndexPage;
}

const { page } = Astro.props;
---

<section class="bg-bg py-20 px-10">
  <div class="max-w-content mx-auto grid grid-cols-1 md:grid-cols-[1.5fr_1fr] gap-16 items-end">
    <div>
      <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-4">
        ◆ {page.heroEyebrow}
      </div>
      <h1
        class="font-serif font-medium text-ink m-0 tracking-display-tight"
        style="font-size: clamp(56px, 8vw, 104px); line-height: 0.94; text-wrap: balance;"
      >
        <HeadlineRichText value={page.heroHeading} />
      </h1>
    </div>
    <p class="m-0 text-muted text-body-lg leading-snug max-w-[480px]">{page.heroDeck}</p>
  </div>
</section>
