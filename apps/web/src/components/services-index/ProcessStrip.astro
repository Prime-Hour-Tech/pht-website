---
import type { ServicesIndexPage } from "../../lib/sanity/types";
import HeadlineRichText from "../HeadlineRichText.astro";

interface Props {
  process: ServicesIndexPage["processStrip"];
}

const { process } = Astro.props;
---

<section class="bg-bg-alt px-10 py-22 border-y border-line">
  <div class="max-w-content mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start mb-12">
      <div>
        <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-3.5">
          ◆ {process.eyebrow}
        </div>
        <h2
          class="font-serif font-medium text-ink m-0 tracking-display-tight"
          style="font-size: 44px; line-height: 1.05; text-wrap: balance;"
        >
          <HeadlineRichText value={process.heading} />
        </h2>
      </div>
      <p class="m-0 text-muted text-body-md leading-body max-w-[540px]">{process.deck}</p>
    </div>

    <ol class="m-0 p-0 list-none grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
      {process.steps.map((step, i) => (
        <li
          class="bg-bg border border-line rounded-lg p-6 flex flex-col gap-3"
        >
          <div class="flex items-center justify-between">
            <span class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase">
              Step {String(i + 1).padStart(2, "0")}
            </span>
            <span
              class="w-7 h-7 rounded-full border border-line inline-flex items-center justify-center font-mono text-[12px] text-ink"
            >
              {i + 1}
            </span>
          </div>
          <h3
            class="font-serif font-medium text-ink m-0"
            style="font-size: 24px; letter-spacing: -0.015em; line-height: 1.15;"
          >
            {step.title}
          </h3>
          <p class="m-0 text-muted text-[14px] leading-body">{step.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
