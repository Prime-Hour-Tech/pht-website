---
import type { ServiceCard } from "../../lib/sanity/types";
import Icon from "../Icon.astro";

interface Props {
  service: ServiceCard;
  // 1-based position in the full services list, e.g. "02 of 06"
  positionLabel: string;
}

const { service, positionLabel } = Astro.props;
---

<a
  id={service.slug}
  href={`/services/${service.slug}`}
  class="bg-bg border border-line rounded-xl p-7 no-underline text-ink flex flex-col min-h-[380px] hover:border-accent/40 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
>
  <div class="flex items-center justify-between mb-5">
    <span
      class="w-11 h-11 rounded-lg bg-accent/10 text-accent border border-accent/20 inline-flex items-center justify-center"
    >
      <Icon name={service.iconName} size={20} />
    </span>
    <span class="font-mono text-meta text-muted tracking-mono-eyebrow uppercase">
      {positionLabel}
    </span>
  </div>

  <h3
    class="font-serif font-medium text-ink m-0"
    style="font-size: 30px; letter-spacing: -0.02em; line-height: 1.05;"
  >
    {service.name}
  </h3>
  <div class="mt-2 font-mono text-[11.5px] text-muted tracking-mono-eyebrow uppercase">
    Service · {positionLabel}
  </div>

  <p class="mt-4 text-muted text-[14.5px] leading-body">{service.shortDescription}</p>

  <div class="mt-auto pt-6 flex items-end justify-between gap-3">
    <span class="text-accent font-semibold text-[13px] inline-flex items-center gap-1.5">
      Read spec <Icon name="arrow" size={14} />
    </span>
  </div>
</a>
