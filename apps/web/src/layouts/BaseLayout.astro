---
import "../styles/global.css";
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";
import "@fontsource-variable/newsreader";
import "@fontsource-variable/newsreader/wght-italic.css";
import SEO from "../components/SEO.astro";
import JsonLd from "../components/JsonLd.astro";
import Analytics from "../components/Analytics.astro";
import UtilityRow from "../components/chrome/UtilityRow.astro";
import SiteNav from "../components/chrome/SiteNav.astro";
import Footer from "../components/chrome/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";
import { VisualEditing } from "@sanity/astro/visual-editing";
import {
  getContactInfo,
  getFooter,
  getNavigation,
  getSiteSettings,
  getTheme,
} from "../lib/sanity/client";
import { themeToCssVars, warnThemeContrastOnce } from "../lib/sanity/theme";
import { buildOrganizationJsonLd } from "../lib/structuredData";
import { ogImageUrl } from "../lib/sanity/imageUrl";
import type { ImageRef } from "../lib/sanity/types";

interface Props {
  title: string;
  /** Per-page meta description. Falls back to siteSettings.siteDescription when omitted. */
  description?: string;
  /** Per-page canonical URL. Defaults to the page's own absolute URL when omitted. */
  canonical?: string;
  ogImage?: ImageRef;
  /** Render <meta name="robots" content="noindex, nofollow">. Used by paid-ad landers. */
  noindex?: boolean;
  prevUrl?: string;
  nextUrl?: string;
}

const { title, description: descriptionProp, canonical, ogImage, noindex, prevUrl, nextUrl } = Astro.props;

// Canonical defaults to the page's own absolute URL when a caller doesn't pass one.
const resolvedCanonical =
  canonical ?? new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();

// Chrome data: parallel fetch. Each is required; missing = misconfiguration,
// surface as a build failure with a helpful message.
const [siteSettings, navigation, footer, contactInfo, theme] = await Promise.all([
  getSiteSettings(),
  getNavigation(),
  getFooter(),
  getContactInfo(),
  getTheme(),
]);

if (!siteSettings) {
  throw new Error(
    "Site Settings document is missing in Sanity. Create and publish it in the Studio first.",
  );
}
if (!navigation) {
  throw new Error(
    "Navigation singleton not found in Sanity. Open the Studio and publish the Navigation document before deploying.",
  );
}
if (!footer) {
  throw new Error(
    "Footer singleton not found in Sanity. Open the Studio and publish the Footer document before deploying.",
  );
}
if (!contactInfo) {
  throw new Error(
    "Contact Info singleton not found in Sanity. Open the Studio and publish the Contact Info document before deploying.",
  );
}

const siteUrl = (Astro.site ?? new URL("/", Astro.url.origin)).toString().replace(/\/$/, "");
const organizationLd = buildOrganizationJsonLd({
  siteSettings,
  contactInfo,
  footer,
  siteUrl,
});
const resolvedOgImageUrl = ogImageUrl(ogImage, siteSettings.defaultOgImage);
const enableVisualEditing = import.meta.env.PUBLIC_SANITY_VISUAL_EDITING === "true";
const themeVars = themeToCssVars(theme);
warnThemeContrastOnce(theme);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title={title}
      description={descriptionProp ?? siteSettings.siteDescription}
      canonical={resolvedCanonical}
      siteName={siteSettings.siteName}
      ogImageUrl={resolvedOgImageUrl}
    />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${siteSettings.siteName} Blog`}
      href="/blog/rss.xml"
    />
    {prevUrl && <link rel="prev" href={prevUrl} />}
    {nextUrl && <link rel="next" href={nextUrl} />}
    <JsonLd data={organizationLd} />
    <Analytics />
    {themeVars && <style is:inline set:html={`:root{\n${themeVars}\n}`}></style>}
  </head>
  <body class="bg-bg text-ink-body antialiased">
    <UtilityRow contactInfo={contactInfo} />
    <SiteNav
      siteSettings={siteSettings}
      navigation={navigation}
      contactInfo={contactInfo}
    />
    <main>
      <slot />
    </main>
    <Footer
      footer={footer}
      siteSettings={siteSettings}
      contactInfo={contactInfo}
    />
    <CookieBanner />
    <VisualEditing enabled={enableVisualEditing} />
  </body>
</html>
