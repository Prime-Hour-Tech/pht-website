---
import "../styles/global.css";
import SEO from "../components/SEO.astro";
import JsonLd from "../components/JsonLd.astro";
import UtilityRow from "../components/chrome/UtilityRow.astro";
import SiteNav from "../components/chrome/SiteNav.astro";
import Footer from "../components/chrome/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";
import {
  getContactInfo,
  getFooter,
  getNavigation,
  getSiteSettings,
} from "../lib/sanity/client";
import { buildOrganizationJsonLd } from "../lib/structuredData";

interface Props {
  title: string;
  /** Per-page meta description. Falls back to siteSettings.siteDescription when omitted. */
  description?: string;
  canonical: string;
  ogImageUrl?: string;
}

const { title, description: descriptionProp, canonical, ogImageUrl } = Astro.props;

// Chrome data — parallel fetch. Each is required; missing = misconfiguration,
// surface as a build failure with a helpful message.
const [siteSettings, navigation, footer, contactInfo] = await Promise.all([
  getSiteSettings(),
  getNavigation(),
  getFooter(),
  getContactInfo(),
]);

if (!siteSettings) {
  throw new Error(
    "Site Settings document is missing in Sanity. Create and publish it in the Studio first.",
  );
}
if (!navigation) {
  throw new Error(
    "Navigation singleton not found in Sanity. Open the Studio and publish the Navigation document before deploying.",
  );
}
if (!footer) {
  throw new Error(
    "Footer singleton not found in Sanity. Open the Studio and publish the Footer document before deploying.",
  );
}
if (!contactInfo) {
  throw new Error(
    "Contact Info singleton not found in Sanity. Open the Studio and publish the Contact Info document before deploying.",
  );
}

const siteUrl = (Astro.site ?? new URL("/", Astro.url.origin)).toString().replace(/\/$/, "");
const organizationLd = buildOrganizationJsonLd({
  siteSettings,
  contactInfo,
  footer,
  siteUrl,
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&family=Newsreader:ital,wght@0,400;0,500;0,600;1,500&display=swap"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title={title}
      description={descriptionProp ?? siteSettings.siteDescription}
      canonical={canonical}
      siteName={siteSettings.siteName}
      ogImageUrl={ogImageUrl}
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${siteSettings.siteName} Blog`}
      href="/blog/rss.xml"
    />
    <JsonLd data={organizationLd} />
  </head>
  <body class="bg-bg text-ink-body antialiased">
    <UtilityRow contactInfo={contactInfo} />
    <SiteNav
      siteSettings={siteSettings}
      navigation={navigation}
      contactInfo={contactInfo}
    />
    <main>
      <slot />
    </main>
    <Footer
      footer={footer}
      siteSettings={siteSettings}
      contactInfo={contactInfo}
    />
    <CookieBanner />
  </body>
</html>
