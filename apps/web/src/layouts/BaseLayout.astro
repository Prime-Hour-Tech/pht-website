---
import "../styles/global.css";
import SEO from "../components/SEO.astro";

interface Props {
  title: string;
  description: string;
  canonical: string;
  siteName: string;
  ogImageUrl?: string;
}

const { title, description, canonical, siteName, ogImageUrl } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      siteName={siteName}
      ogImageUrl={ogImageUrl}
    />
  </head>
  <body class="bg-white text-slate-900 antialiased">
    <slot />
  </body>
</html>
