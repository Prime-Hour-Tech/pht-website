---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlockRenderer from "../components/blocks/BlockRenderer.astro";
import { getAllPageSlugs, getPageBySlug, getContactInfo } from "../lib/sanity/client";

export async function getStaticPaths() {
  // These slugs are served by dedicated route files (services/index.astro,
  // switching.astro, blog/[...page].astro) that take priority. Excluding them
  // here stops this catch-all from also emitting /services, /switching, and
  // /blog — which Astro otherwise drops with a "conflicts with higher priority
  // route" build warning — and keeps it to genuinely generic pages (home,
  // about, contact, industries). Add a slug here when a page gains its own route.
  const dedicatedRouteSlugs = new Set(["blog", "services", "switching"]);
  const slugs = await getAllPageSlugs();
  return slugs
    .filter(({ slug }) => !dedicatedRouteSlugs.has(slug))
    .map(({ slug }) => ({
      params: { slug: slug === "home" ? undefined : slug },
      props: { slug },
    }));
}

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const [page, contactInfo] = await Promise.all([
  getPageBySlug(slug),
  getContactInfo(),
]);

if (!page) {
  throw new Error(`Page not found in Sanity for slug: ${slug}`);
}
if (!contactInfo) {
  throw new Error("Contact Info singleton not found in Sanity.");
}

const title = page.seoTitle ?? page.title;
// description falls back to siteSettings.siteDescription inside BaseLayout
const description = page.seoDescription ?? undefined;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={page.ogImage}
>
  {page.blocks?.map((block) => <BlockRenderer block={block} contactInfo={contactInfo} />)}
</BaseLayout>
