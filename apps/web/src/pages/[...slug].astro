---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlockRenderer from "../components/blocks/BlockRenderer.astro";
import {
  getAllPageSlugs,
  getPageBySlug,
  getSiteSettings,
} from "../lib/sanity/client";

export async function getStaticPaths() {
  const slugs = await getAllPageSlugs();
  return slugs.map(({ slug }) => ({
    params: { slug: slug === "home" ? undefined : slug },
    props: { slug },
  }));
}

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const [page, siteSettings] = await Promise.all([
  getPageBySlug(slug),
  getSiteSettings(),
]);

if (!page) {
  throw new Error(`Page not found in Sanity for slug: ${slug}`);
}
if (!siteSettings) {
  throw new Error(
    "Site Settings document is missing in Sanity. Create and publish it in the Studio first.",
  );
}

const title = page.seoTitle ?? page.title;
const description = page.seoDescription ?? siteSettings.siteDescription;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  siteName={siteSettings.siteName}
>
  {page.blocks?.map((block) => <BlockRenderer block={block} />)}
</BaseLayout>
