---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/blocks/Hero.astro";
import {
  getAllPageSlugs,
  getPageBySlug,
  getSiteSettings,
} from "../lib/sanity/client";
import type { PageBlock } from "../lib/sanity/types";

export async function getStaticPaths() {
  const slugs = await getAllPageSlugs();
  return slugs.map(({ slug }) => ({
    params: { slug: slug === "home" ? undefined : slug },
    props: { slug },
  }));
}

interface Props {
  slug: string;
}

const { slug } = Astro.props;
// Note: getSiteSettings() is called once per page generated. For v1's small
// page count this is fine — Sanity is fast, builds are infrequent. If page
// counts grow, hoist this fetch to module scope or memoize at config time.
const [page, siteSettings] = await Promise.all([
  getPageBySlug(slug),
  getSiteSettings(),
]);

if (!page) {
  throw new Error(`Page not found in Sanity for slug: ${slug}`);
}
if (!siteSettings) {
  throw new Error(
    "Site Settings document is missing in Sanity. Create and publish it in the Studio first.",
  );
}

const title = page.seoTitle ?? page.title;
const description = page.seoDescription ?? siteSettings.siteDescription;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  siteName={siteSettings.siteName}
>
  {page.blocks?.map((block: PageBlock) => {
    if (block._type === "hero") {
      return <Hero block={block} />;
    }
    return null;
  })}
</BaseLayout>
