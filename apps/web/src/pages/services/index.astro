---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlockRenderer from "../../components/blocks/BlockRenderer.astro";
import { getPageBySlug, getContactInfo } from "../../lib/sanity/client";

const [page, contactInfo] = await Promise.all([
  getPageBySlug("services"),
  getContactInfo(),
]);

if (!page) {
  throw new Error(
    "Page doc with slug 'services' not found in Sanity. Create a `page` document with slug 'services' in the Studio and author the blocks per the design (servicesIndexHero → pricingTiers → bundleGrid → processStrip → industryCrosslink → ctaCard).",
  );
}
if (!contactInfo) {
  throw new Error("Contact Info singleton not found in Sanity.");
}

const canonical = new URL("/services", Astro.site ?? Astro.url.origin).toString();
---

<BaseLayout
  title={page.seoTitle ?? page.title}
  description={page.seoDescription}
  canonical={canonical}
  ogImage={page.ogImage}
>
  {page.blocks?.map((block) => <BlockRenderer block={block} contactInfo={contactInfo} />)}
</BaseLayout>
