---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ServicesIndexHero from "../../components/service/ServicesIndexHero.astro";
import HeadlineRichText from "../../components/HeadlineRichText.astro";
import CtaCard from "../../components/blocks/CtaCard.astro";
import FeaturedServiceCard from "../../components/services-index/FeaturedServiceCard.astro";
import PricingTiers from "../../components/services-index/PricingTiers.astro";
import ServiceGridCard from "../../components/services-index/ServiceGridCard.astro";
import BundleTile from "../../components/services-index/BundleTile.astro";
import ProcessStrip from "../../components/services-index/ProcessStrip.astro";
import IndustryCrosslink from "../../components/services-index/IndustryCrosslink.astro";
import Icon from "../../components/Icon.astro";
import {
  getServicesList,
  getServicesIndexPage,
} from "../../lib/sanity/client";
import type { CtaCardBlock } from "../../lib/sanity/types";

const [services, indexPage] = await Promise.all([
  getServicesList(),
  getServicesIndexPage(),
]);

if (!indexPage) {
  throw new Error("Services Index Page singleton not found in Sanity.");
}

const featuredSlug = indexPage.featuredService.slug;
const restServices = services.filter((s) => s.slug !== featuredSlug);
const totalLabel = String(services.length).padStart(2, "0");

const ctaBlock: CtaCardBlock = {
  _type: "ctaCard",
  _key: "services-cta",
  eyebrow: `◆ ${indexPage.ctaEyebrow}`,
  heading: indexPage.ctaHeading,
  deck: indexPage.ctaDeck,
  primaryCtaLabel: indexPage.ctaLabel,
  primaryCtaHref: indexPage.ctaHref,
};
---

<BaseLayout
  title="Services"
  description="Managed IT, cybersecurity, cloud, projects, advisory, and web — six services run by one Salt Lake City team."
>
  <ServicesIndexHero
    eyebrow={indexPage.heroEyebrow}
    heading={indexPage.heroHeading}
    deck={indexPage.heroDeck}
  />

  <!-- Sticky jump-chip row -->
  <section class="bg-bg-alt border-y border-line sticky top-0 z-10 px-10 py-5">
    <div class="max-w-content mx-auto flex items-center gap-2.5 flex-wrap">
      <span class="font-mono text-meta text-muted tracking-mono-eyebrow uppercase">
        Jump to:
      </span>
      {services.map((s) => (
        <a
          href={`#${s.slug}`}
          class="inline-flex items-center gap-2 px-3.5 py-2 rounded-full border border-line bg-bg text-ink no-underline text-[13.5px] font-medium hover:border-accent/40 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
        >
          <Icon name={s.iconName} size={13} />
          {s.name}
        </a>
      ))}
      <span class="ml-auto inline-flex items-center gap-2 font-mono text-meta text-muted tracking-mono-eyebrow uppercase">
        <span class="w-2 h-2 rounded-full bg-[#22c55e] inline-block"></span>
        Same engineer, same number
      </span>
    </div>
  </section>

  <FeaturedServiceCard
    service={indexPage.featuredService}
    indexLabel={`01 / ${totalLabel}`}
  />

  <PricingTiers
    heading={indexPage.pricingHeading}
    tiers={indexPage.pricingTiers}
    footerNote={indexPage.pricingFooterNote}
    footerLinkLabel={indexPage.pricingFooterLinkLabel}
    footerLinkHref={indexPage.pricingFooterLinkHref}
  />

  <!-- Service grid + bundle tile -->
  <section class="bg-bg px-10 py-22 pt-8">
    <div class="max-w-content mx-auto">
      <div class="flex items-baseline justify-between gap-4 flex-wrap mb-7">
        <div>
          <div class="font-mono text-meta text-accent tracking-mono-eyebrow uppercase mb-3">
            ◆ {indexPage.gridHeading.eyebrow}
          </div>
          <h2
            class="font-serif font-medium text-ink m-0 tracking-display-tight"
            style="font-size: 44px; line-height: 1.05;"
          >
            <HeadlineRichText value={indexPage.gridHeading.heading} />
          </h2>
        </div>
        {indexPage.gridHeading.secondaryLinkLabel && indexPage.gridHeading.secondaryLinkHref && (
          <a
            href={indexPage.gridHeading.secondaryLinkHref}
            class="text-accent no-underline font-semibold text-[14px]"
          >
            {indexPage.gridHeading.secondaryLinkLabel}
          </a>
        )}
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {restServices.map((s, i) => (
          <ServiceGridCard
            service={s}
            positionLabel={`0${i + 2} of ${totalLabel}`}
          />
        ))}
        <BundleTile bundle={indexPage.bundleTile} />
      </div>
    </div>
  </section>

  <ProcessStrip process={indexPage.processStrip} />

  <IndustryCrosslink crosslink={indexPage.industryCrosslink} />

  <CtaCard block={ctaBlock} />
</BaseLayout>
