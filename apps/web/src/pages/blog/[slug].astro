---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/chrome/Breadcrumb.astro";
import BlogPostHeader from "../../components/blog/BlogPostHeader.astro";
import BlogPostCover from "../../components/blog/BlogPostCover.astro";
import BlogPostBody from "../../components/blog/BlogPostBody.astro";
import AuthorBioCard from "../../components/blog/AuthorBioCard.astro";
import RelatedPosts from "../../components/blog/RelatedPosts.astro";
import {
  getAllPostSlugs,
  getPostBySlug,
  getRelatedPosts,
} from "../../lib/sanity/client";

export async function getStaticPaths() {
  const slugs = await getAllPostSlugs();
  return slugs
    .filter((s) => s.slug)
    .map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
if (!slug) {
  throw new Error("Post slug missing at build time.");
}

const post = await getPostBySlug(slug);
if (!post) {
  throw new Error(`Post not found in Sanity for slug: ${slug}`);
}

const related = await getRelatedPosts(post.category, slug);
const url = new URL(`/blog/${slug}`, Astro.site ?? Astro.url.origin).toString();
---

<BaseLayout
  title={post.seoTitle ?? post.title}
  description={post.seoDescription ?? post.excerpt}
>
  <Breadcrumb trail={[{ label: "Blog", href: "/blog" }, post.title]} />

  <BlogPostHeader post={post} url={url} />
  <BlogPostCover post={post} />
  <BlogPostBody post={post} />
  <AuthorBioCard author={post.author} />
  <RelatedPosts posts={related} />
</BaseLayout>
