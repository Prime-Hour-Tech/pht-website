SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2026-05-01
SANITY_READ_TOKEN=
SITE_URL=http://localhost:4321

# Contact form provider action URL. Set this to your form provider's POST endpoint
# (Web3Forms / Formspree / Basin etc.). If unset at build, the contact form falls
# back to action="#" and emits a console warning during prerender.
CONTACT_FORM_URL=

# Cookie banner gate. Set to "true" only after legal copy + tracking choices
# are finalized. Default off — banner doesn't render at all.
PUBLIC_COOKIE_BANNER_ENABLED=false

# Google Tag Manager container ID (e.g. GTM-XXXXXXX). When set, the Analytics
# component ships a consent-gated loader: GTM injects only when the user has
# clicked "Accept" on the cookie banner (localStorage["pht-cookie-consent"]
# === "accepted"). When unset, no analytics scripts ship at all.
PUBLIC_GTM_CONTAINER_ID=
